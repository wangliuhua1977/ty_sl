    <SolidColorBrush x:Key="ListItemHoverBackgroundBrush" Color="#F1F6FF" />
    <SolidColorBrush x:Key="ListItemBorderBrush" Color="#D9E3EE" />
    <SolidColorBrush x:Key="ListItemSelectedBackgroundBrush" Color="#EAF1FF" />
