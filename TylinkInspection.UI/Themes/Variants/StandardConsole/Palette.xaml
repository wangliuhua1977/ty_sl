    <SolidColorBrush x:Key="TodoCardBackgroundBrush" Color="#F9FBFD" />
    <SolidColorBrush x:Key="MapOverlayLabelBackgroundBrush" Color="#F6FFFFFF" />

    <LinearGradientBrush x:Key="MapSurfaceBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0" Color="#FBFCFE" />
        <GradientStop Offset="0.45" Color="#F5F8FC" />
        <GradientStop Offset="1" Color="#EEF3F8" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="MapBorderBrush" Color="#CFDBE8" />
    <SolidColorBrush x:Key="MapPathPrimaryBrush" Color="#7E9FC6" />
    <SolidColorBrush x:Key="MapPathSecondaryBrush" Color="#A5BDDA" />
