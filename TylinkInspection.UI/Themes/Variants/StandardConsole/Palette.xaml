    <SolidColorBrush x:Key="ActionButtonBorderBrush" Color="#9FBCE8" />
    <SolidColorBrush x:Key="ActionButtonHoverBackgroundBrush" Color="#DDE9FF" />
    <SolidColorBrush x:Key="ActionButtonForegroundBrush" Color="#1F4FAF" />
