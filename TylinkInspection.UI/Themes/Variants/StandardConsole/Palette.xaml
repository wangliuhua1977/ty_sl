    <SolidColorBrush x:Key="NavigationSelectedBorderBrush" Color="#2F6FEB" />
    <SolidColorBrush x:Key="SelectionCardBackgroundBrush" Color="#F8FAFD" />
    <SolidColorBrush x:Key="SelectionCardBorderBrush" Color="#D9E2ED" />
    <SolidColorBrush x:Key="SelectionCardHoverBackgroundBrush" Color="#F2F7FF" />
