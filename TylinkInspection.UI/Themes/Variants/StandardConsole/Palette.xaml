    <SolidColorBrush x:Key="MapRegionBorderBrush" Color="#A1BCD8" />
    <SolidColorBrush x:Key="MapInnerRegionFillBrush" Color="#DFEAF6" />
    <SolidColorBrush x:Key="MapInnerRegionBorderBrush" Color="#89A9CB" />
    <SolidColorBrush x:Key="MapMarkerStrokeBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="RadarPrimaryStrokeBrush" Color="#C3D4E6" />
    <SolidColorBrush x:Key="RadarSecondaryStrokeBrush" Color="#D4E1EF" />
    <SolidColorBrush x:Key="RadarMidStrokeBrush" Color="#B8CCE2" />
    <SolidColorBrush x:Key="RadarInnerStrokeBrush" Color="#A9C1DB" />
    <SolidColorBrush x:Key="RadarSweepBrush" Color="#2F6FEB" />

    <DrawingBrush x:Key="MapGridBrush"
                  TileMode="Tile"
                  Viewport="0,0,40,40"
                  ViewportUnits="Absolute"
                  Stretch="None">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="Transparent">
                    <GeometryDrawing.Pen>
                        <Pen Brush="#D9E4F0" Thickness="1" />
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="0,0" EndPoint="40,0" />
                            <LineGeometry StartPoint="0,0" EndPoint="0,40" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>
</ResourceDictionary>
