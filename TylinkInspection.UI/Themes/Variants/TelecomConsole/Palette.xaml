    <SolidColorBrush x:Key="MapRegionBorderBrush" Color="#9BB9D6" />
    <SolidColorBrush x:Key="MapInnerRegionFillBrush" Color="#DDEAF7" />
    <SolidColorBrush x:Key="MapInnerRegionBorderBrush" Color="#83A6CB" />
    <SolidColorBrush x:Key="MapMarkerStrokeBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="RadarPrimaryStrokeBrush" Color="#C3D4E6" />
    <SolidColorBrush x:Key="RadarSecondaryStrokeBrush" Color="#D5E1ED" />
    <SolidColorBrush x:Key="RadarMidStrokeBrush" Color="#B9CCE1" />
    <SolidColorBrush x:Key="RadarInnerStrokeBrush" Color="#ACC2DA" />
    <SolidColorBrush x:Key="RadarSweepBrush" Color="#1B6FD6" />

    <DrawingBrush x:Key="MapGridBrush"
                  TileMode="Tile"
                  Viewport="0,0,40,40"
                  ViewportUnits="Absolute"
                  Stretch="None">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="Transparent">
                    <GeometryDrawing.Pen>
                        <Pen Brush="#D8E4F0" Thickness="1" />
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="0,0" EndPoint="40,0" />
                            <LineGeometry StartPoint="0,0" EndPoint="0,40" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>
</ResourceDictionary>
