    <SolidColorBrush x:Key="TodoCardBackgroundBrush" Color="#F9FBFD" />
    <SolidColorBrush x:Key="MapOverlayLabelBackgroundBrush" Color="#F7FFFFFF" />

    <LinearGradientBrush x:Key="MapSurfaceBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0" Color="#FDFEFF" />
        <GradientStop Offset="0.45" Color="#F5F9FD" />
        <GradientStop Offset="1" Color="#EDF3F9" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="MapBorderBrush" Color="#CFDDEA" />
    <SolidColorBrush x:Key="MapPathPrimaryBrush" Color="#7B9EC6" />
    <SolidColorBrush x:Key="MapPathSecondaryBrush" Color="#A4BDD9" />
