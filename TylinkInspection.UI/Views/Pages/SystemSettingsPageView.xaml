<UserControl x:Class="TylinkInspection.UI.Views.Pages.SystemSettingsPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,4">
            <Border Style="{StaticResource PanelCardStyle}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{Binding PageTitle}" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource SectionHintStyle}"
                                   TextWrapping="Wrap"
                                   Text="{Binding PageSubtitle}" />
                    </StackPanel>
                    <Border DockPanel.Dock="Right"
                            Style="{StaticResource MiniBadgeStyle}"
                            Background="{DynamicResource FilterBadgeBackgroundBrush}">
                        <TextBlock Text="PLATFORM TOKEN" />
                    </Border>
                </DockPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="1.3*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource PanelCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Platform Configuration" />
                        <TextBlock Margin="0,8,0,18"
                                   Style="{StaticResource SectionHintStyle}"
                                   TextWrapping="Wrap"
                                   Text="Maintain configuration under the TylinkInspection.App project directory. Build will copy supported JSON files to the runtime output directory automatically." />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="BaseUrl" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource FieldValueStyle}" Text="{Binding BaseUrl}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,10,0,4" Style="{StaticResource FieldLabelStyle}" Text="AppId" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding MaskedAppId}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,10,0,4" Style="{StaticResource FieldLabelStyle}" Text="EnterpriseUser" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding MaskedEnterpriseUser}" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,10,0,4" Style="{StaticResource FieldLabelStyle}" Text="ParentUser" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding MaskedParentUser}" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,10,0,4" Style="{StaticResource FieldLabelStyle}" Text="GrantType" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding GrantType}" />

                            <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,10,0,4" Style="{StaticResource FieldLabelStyle}" Text="ClientType" />
                            <TextBlock Grid.Row="5" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding ClientType}" />

                            <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,10,0,4" Style="{StaticResource FieldLabelStyle}" Text="Version" />
                            <TextBlock Grid.Row="6" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding Version}" />

                            <TextBlock Grid.Row="7" Grid.Column="0" Margin="0,10,0,4" Style="{StaticResource FieldLabelStyle}" Text="ApiVersion" />
                            <TextBlock Grid.Row="7" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding ApiVersion}" />

                            <TextBlock Grid.Row="8" Grid.Column="0" Margin="0,10,0,4" Style="{StaticResource FieldLabelStyle}" Text="DecryptionMode" />
                            <TextBlock Grid.Row="8" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding DecryptionMode}" />

                            <TextBlock Grid.Row="9" Grid.Column="0" Margin="0,10,0,4" Style="{StaticResource FieldLabelStyle}" Text="RecommendedDir" />
                            <TextBlock Grid.Row="9" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding RecommendedSettingsDirectoryPath}" TextWrapping="Wrap" />

                            <TextBlock Grid.Row="10" Grid.Column="0" Margin="0,10,0,4" Style="{StaticResource FieldLabelStyle}" Text="RuntimeOutputDir" />
                            <TextBlock Grid.Row="10" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding RuntimeSettingsDirectoryPath}" TextWrapping="Wrap" />

                            <TextBlock Grid.Row="11" Grid.Column="0" Margin="0,10,0,4" Style="{StaticResource FieldLabelStyle}" Text="ActiveSource" />
                            <TextBlock Grid.Row="11" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding ConfigurationSourceSummary}" TextWrapping="Wrap" />

                            <TextBlock Grid.Row="12" Grid.Column="0" Margin="0,10,0,4" Style="{StaticResource FieldLabelStyle}" Text="ActiveDir" />
                            <TextBlock Grid.Row="12" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding ConfigurationRootPath}" TextWrapping="Wrap" />

                            <TextBlock Grid.Row="13" Grid.Column="0" Margin="0,10,0,4" Style="{StaticResource FieldLabelStyle}" Text="appsettings.json" />
                            <TextBlock Grid.Row="13" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SharedSettingsPath}" TextWrapping="Wrap" />

                            <TextBlock Grid.Row="14" Grid.Column="0" Margin="0,10,0,4" Style="{StaticResource FieldLabelStyle}" Text="appsettings.Local.json" />
                            <TextBlock Grid.Row="14" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding LocalSettingsPath}" TextWrapping="Wrap" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource PanelCardStyle}">
                    <StackPanel>
                        <DockPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Token Status" />
                            <Border DockPanel.Dock="Right"
                                    Style="{StaticResource StatusBadgeBorderStyle}"
                                    BorderBrush="{Binding TokenStateAccentResourceKey, Converter={StaticResource ResourceLookupConverter}}">
                                <TextBlock Foreground="{Binding TokenStateAccentResourceKey, Converter={StaticResource ResourceLookupConverter}}"
                                           Text="{Binding TokenStatusSummary}" />
                            </Border>
                        </DockPanel>
                        <TextBlock Margin="0,8,0,18"
                                   Style="{StaticResource SectionHintStyle}"
                                   Text="Only masked token state and expiry information are shown on this page." />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="AccessToken" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource FieldValueStyle}" Text="{Binding MaskedAccessToken}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,10,0,4" Style="{StaticResource FieldLabelStyle}" Text="RefreshToken" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding MaskedRefreshToken}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,10,0,4" Style="{StaticResource FieldLabelStyle}" Text="AccessTokenExpireAt" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding AccessTokenExpireAtText}" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,10,0,4" Style="{StaticResource FieldLabelStyle}" Text="RefreshTokenExpireAt" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding RefreshTokenExpireAtText}" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,10,0,4" Style="{StaticResource FieldLabelStyle}" Text="UpdatedAt" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding UpdatedAtText}" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource PanelCardStyle}">
                <StackPanel>
                    <DockPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Connection Diagnostics" />
                        <Border DockPanel.Dock="Right"
                                Style="{StaticResource StatusBadgeBorderStyle}"
                                BorderBrush="{Binding ConnectionAccentResourceKey, Converter={StaticResource ResourceLookupConverter}}">
                            <TextBlock Foreground="{Binding ConnectionAccentResourceKey, Converter={StaticResource ResourceLookupConverter}}"
                                       Text="{Binding ConnectionSummary}" />
                        </Border>
                    </DockPanel>

                    <TextBlock Margin="0,8,0,18"
                               Style="{StaticResource SectionHintStyle}"
                               Text="{Binding BusyText}" />

                    <WrapPanel Margin="0,0,0,18">
                        <Button Style="{StaticResource ActionButtonStyle}"
                                Command="{Binding TestConnectionCommand}"
                                Content="Test Connection" />
                        <Button Style="{StaticResource ActionButtonStyle}"
                                Command="{Binding RefreshTokenCommand}"
                                Content="Refresh Token" />
                    </WrapPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="1.2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="ErrorCode" />
                        <TextBlock Grid.Column="1" Style="{StaticResource FieldValueStyle}" Text="{Binding ConnectionErrorCode}" />
                        <TextBlock Grid.Column="3" Style="{StaticResource FieldLabelStyle}" Text="ErrorMessage" />
                        <TextBlock Grid.Column="4"
                                   Style="{StaticResource FieldValueStyle}"
                                   Text="{Binding ConnectionErrorMessage}" />
                    </Grid>

                    <ItemsControl Margin="0,18,0,0" ItemsSource="{Binding DiagnosticMessages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="14"
                                        Background="{DynamicResource AlertItemBackgroundBrush}"
                                        BorderBrush="{Binding DataContext.ConnectionAccentResourceKey, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource ResourceLookupConverter}}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource InnerCardCornerRadius}">
                                    <TextBlock TextWrapping="Wrap" Text="{Binding}" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
