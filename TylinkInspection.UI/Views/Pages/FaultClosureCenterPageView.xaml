<UserControl x:Class="TylinkInspection.UI.Views.Pages.FaultClosureCenterPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             xmlns:sharedPages="clr-namespace:TylinkInspection.UI.Views.Pages.Shared"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,4">
            <Border Style="{StaticResource PanelCardStyle}">
                <StackPanel>
                    <DockPanel>
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{Binding PageTitle}" />
                            <TextBlock Margin="0,8,0,0" Style="{StaticResource SectionHintStyle}" TextWrapping="Wrap" Text="{Binding PageSubtitle}" />
                            <TextBlock Margin="0,12,0,0" Style="{StaticResource SectionHintStyle}" TextWrapping="Wrap" Text="{Binding StatusText}" />
                            <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource ToneDangerBrush}" TextWrapping="Wrap" Text="{Binding WarningText}" />
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                            <Border Style="{StaticResource MiniBadgeStyle}" Background="{DynamicResource FilterBadgeBackgroundBrush}" BorderBrush="{Binding StatusBadgeAccentResourceKey, Converter={StaticResource ResourceLookupConverter}}">
                                <TextBlock Text="{Binding StatusBadgeText}" />
                            </Border>
                            <Border Margin="0,10,0,0" Style="{StaticResource MiniBadgeStyle}" Background="{DynamicResource FilterBadgeBackgroundBrush}">
                                <TextBlock Text="{Binding LastUpdatedText}" />
                            </Border>
                        </StackPanel>
                    </DockPanel>
                    <ItemsControl Margin="0,18,0,0" ItemsSource="{Binding SummaryCards}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <primitives:UniformGrid Columns="5" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,12,0" Padding="14" Background="{DynamicResource MetricTileBackgroundBrush}" BorderBrush="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}" BorderThickness="1" CornerRadius="{StaticResource InnerCardCornerRadius}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding Label}" />
                                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                            <TextBlock FontSize="{StaticResource FontSizeMetric}" FontWeight="Bold" Text="{Binding Value}" />
                                            <TextBlock Margin="6,10,0,0" Foreground="{DynamicResource SecondaryTextBrush}" Text="{Binding Unit}" />
                                        </StackPanel>
                                        <TextBlock Margin="0,8,0,0" Foreground="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}" Text="{Binding DeltaText}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="430" />
                </Grid.ColumnDefinitions>

                <ScrollViewer Grid.Column="0" Margin="0,0,18,0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Style="{StaticResource PanelCardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="筛选条件" />
                                <TextBlock Margin="0,16,0,6" Style="{StaticResource FieldLabelStyle}" Text="闭环状态" />
                                <ComboBox ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding SelectedStatusOption}" DisplayMemberPath="Title" />
                                <TextBlock Margin="0,14,0,6" Style="{StaticResource FieldLabelStyle}" Text="故障类型" />
                                <ComboBox ItemsSource="{Binding FaultTypeOptions}" SelectedItem="{Binding SelectedFaultTypeOption}" DisplayMemberPath="Title" />
                                <TextBlock Margin="0,14,0,6" Style="{StaticResource FieldLabelStyle}" Text="来源类型" />
                                <ComboBox ItemsSource="{Binding SourceOptions}" SelectedItem="{Binding SelectedSourceOption}" DisplayMemberPath="Title" />
                                <CheckBox Margin="0,16,0,0" IsChecked="{Binding PendingRecheckOnly}" Content="只看待复检记录" />
                                <CheckBox Margin="0,8,0,0" IsChecked="{Binding FocusedOnly}" Content="只看重点点位" />
                                <Button Margin="0,18,0,0" Style="{StaticResource ActionButtonStyle}" Command="{Binding RefreshCommand}" IsEnabled="{Binding CanRefresh}" Content="刷新列表" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource PanelCardStyle}">
                            <StackPanel>
                                <DockPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="复检任务队列" />
                                    <Border DockPanel.Dock="Right" Style="{StaticResource MiniBadgeStyle}" Background="{DynamicResource FilterBadgeBackgroundBrush}">
                                        <TextBlock Text="{Binding RecheckTasks.Count, StringFormat=当前 {0} 条}" />
                                    </Border>
                                </DockPanel>
                                <TextBlock Margin="0,10,0,0" Style="{StaticResource SectionHintStyle}" TextWrapping="Wrap" Text="{Binding RecheckQueueStatusText}" />
                                <WrapPanel Margin="0,14,0,0">
                                    <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding AddToRecheckQueueCommand}" IsEnabled="{Binding CanAddToRecheckQueue}" Content="加入复检" />
                                    <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding TriggerSelectedTaskCommand}" IsEnabled="{Binding CanTriggerSelectedTask}" Content="手动执行" />
                                    <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding ToggleSelectedTaskEnabledCommand}" IsEnabled="{Binding CanToggleSelectedTaskEnabled}" Content="{Binding ToggleTaskEnabledButtonText}" />
                                    <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding RefreshRecheckQueueCommand}" Content="刷新队列" />
                                </WrapPanel>
                                <ListBox Margin="0,16,0,0" MaxHeight="300" ItemsSource="{Binding RecheckTasks}" SelectedItem="{Binding SelectedRecheckTask}" Background="Transparent" BorderThickness="0">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Margin" Value="0,0,0,10" />
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="12" Background="{DynamicResource MetricTileBackgroundBrush}" BorderBrush="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}" BorderThickness="1" CornerRadius="{StaticResource InnerCardCornerRadius}">
                                                <StackPanel>
                                                    <DockPanel>
                                                        <TextBlock FontWeight="SemiBold" Text="{Binding DeviceName}" />
                                                        <Border DockPanel.Dock="Right" Style="{StaticResource MiniBadgeStyle}" Background="{DynamicResource FilterBadgeBackgroundBrush}" BorderBrush="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}">
                                                            <TextBlock Text="{Binding CurrentStatusText}" />
                                                        </Border>
                                                    </DockPanel>
                                                    <TextBlock Margin="0,6,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding DeviceCode}" />
                                                    <TextBlock Margin="0,6,0,0" Style="{StaticResource SectionHintStyle}" Text="{Binding NextRunAtText, StringFormat=下次执行：{0}}" />
                                                    <TextBlock Margin="0,4,0,0" Style="{StaticResource SectionHintStyle}" Text="{Binding EnabledStatusText}" />
                                                    <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Text="{Binding LastExecutionSummaryText}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource PanelCardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="本轮边界" />
                                <TextBlock Margin="0,10,0,0" Style="{StaticResource SectionHintStyle}" TextWrapping="Wrap" Text="当前以本地闭环为主，派单草稿、复检、销警与关闭状态全部先落本地，不接真实工单与真实销警接口。" />
                                <TextBlock Margin="0,8,0,0" Style="{StaticResource SectionHintStyle}" TextWrapping="Wrap" Text="复检复用现有基础巡检与播放器宿主能力，右侧仍可联动直播、回看和截图复核。" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Column="1" Margin="0,0,18,0" Style="{StaticResource PanelCardStyle}">
                    <StackPanel>
                        <DockPanel>
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="闭环记录列表" />
                                <TextBlock Margin="0,8,0,0" Style="{StaticResource SectionHintStyle}" Text="{Binding StatusText}" />
                            </StackPanel>
                            <Border DockPanel.Dock="Right" Style="{StaticResource MiniBadgeStyle}" Background="{DynamicResource FilterBadgeBackgroundBrush}">
                                <TextBlock Text="{Binding Records.Count, StringFormat=当前 {0} 条}" />
                            </Border>
                        </DockPanel>
                        <ListBox Margin="0,18,0,0" ItemsSource="{Binding Records}" SelectedItem="{Binding SelectedRecord}" Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,12" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ListItemCardStyle}" BorderBrush="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}">
                                        <DockPanel>
                                            <StackPanel Width="170" DockPanel.Dock="Right">
                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="派单草稿" />
                                                <TextBlock Margin="0,6,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding TicketNumber}" />
                                                <TextBlock Margin="0,12,0,0" Style="{StaticResource FieldLabelStyle}" Text="最近更新" />
                                                <TextBlock Margin="0,6,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding UpdatedAtText}" />
                                            </StackPanel>
                                            <StackPanel Margin="0,0,18,0">
                                                <DockPanel>
                                                    <TextBlock FontSize="15" FontWeight="SemiBold" Text="{Binding DeviceName}" />
                                                    <Border DockPanel.Dock="Right" Style="{StaticResource StatusBadgeBorderStyle}" BorderBrush="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}">
                                                        <TextBlock Foreground="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}" Text="{Binding StatusText}" />
                                                    </Border>
                                                </DockPanel>
                                                <TextBlock Margin="0,8,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding FaultType}" />
                                                <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource SecondaryTextBrush}" Text="{Binding DeviceCode}" />
                                                <WrapPanel Margin="0,10,0,0">
                                                    <Border Style="{StaticResource MiniBadgeStyle}" Background="{DynamicResource FilterBadgeBackgroundBrush}"><TextBlock Text="{Binding SourceTypeText}" /></Border>
                                                    <Border Style="{StaticResource MiniBadgeStyle}" Background="{DynamicResource FilterBadgeBackgroundBrush}"><TextBlock Text="{Binding ReviewConclusionText}" /></Border>
                                                    <Border Style="{StaticResource MiniBadgeStyle}" Background="{DynamicResource FilterBadgeBackgroundBrush}"><TextBlock Text="{Binding PendingFlagsText}" /></Border>
                                                </WrapPanel>
                                                <TextBlock Margin="0,10,0,0" Style="{StaticResource SectionHintStyle}" Text="{Binding EvidenceSummaryText}" />
                                                <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap" Text="{Binding FaultSummary}" />
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Style="{StaticResource PanelCardStyle}">
                            <StackPanel>
                                <DockPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="工单 / 关联详情" />
                                    <Border DockPanel.Dock="Right" Style="{StaticResource MiniBadgeStyle}" Background="{DynamicResource FilterBadgeBackgroundBrush}" BorderBrush="{Binding SelectedRecord.AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}">
                                        <TextBlock Text="{Binding SelectedStatusText}" />
                                    </Border>
                                </DockPanel>
                                <TextBlock Margin="0,12,0,0" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" Text="{Binding SelectedPointNameText}" />
                                <TextBlock Margin="0,6,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedPointCodeText}" />
                                <TextBlock Margin="0,10,0,0" Style="{StaticResource SectionHintStyle}" TextWrapping="Wrap" Text="{Binding SelectedSummaryText}" />
                                <TextBlock Margin="0,16,0,0" Style="{StaticResource FieldLabelStyle}" Text="工单编号" />
                                <TextBlock Margin="0,6,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedTicketNumber}" />
                                <WrapPanel Margin="0,14,0,0">
                                    <Border Style="{StaticResource MiniBadgeStyle}" Background="{DynamicResource FilterBadgeBackgroundBrush}"><TextBlock Text="{Binding SelectedSourceText}" /></Border>
                                    <Border Style="{StaticResource MiniBadgeStyle}" Background="{DynamicResource FilterBadgeBackgroundBrush}"><TextBlock Text="{Binding SelectedFaultTypeText}" /></Border>
                                    <Border Style="{StaticResource MiniBadgeStyle}" Background="{DynamicResource FilterBadgeBackgroundBrush}"><TextBlock Text="{Binding SelectedReviewConclusionText}" /></Border>
                                </WrapPanel>
                                <TextBlock Margin="0,14,0,0" Style="{StaticResource FieldLabelStyle}" Text="关联目录" />
                                <TextBlock Margin="0,6,0,0" Style="{StaticResource FieldValueStyle}" TextWrapping="Wrap" Text="{Binding SelectedDirectoryText}" />
                                <TextBlock Margin="0,14,0,0" Style="{StaticResource FieldLabelStyle}" Text="证据索引" />
                                <TextBlock Margin="0,6,0,0" Style="{StaticResource FieldValueStyle}" TextWrapping="Wrap" Text="{Binding SelectedEvidenceSummaryText}" />
                                <TextBlock Margin="0,14,0,0" Style="{StaticResource FieldLabelStyle}" Text="AI 告警 / 回看" />
                                <TextBlock Margin="0,6,0,0" Style="{StaticResource FieldValueStyle}" TextWrapping="Wrap" Text="{Binding SelectedAiAlertText}" />
                                <TextBlock Margin="0,6,0,0" Style="{StaticResource FieldValueStyle}" TextWrapping="Wrap" Text="{Binding SelectedPlaybackText}" />
                                <TextBlock Margin="0,14,0,0" Style="{StaticResource FieldLabelStyle}" Text="证据时间 / 最新动作" />
                                <TextBlock Margin="0,6,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedPrimaryEvidenceTimeText}" />
                                <TextBlock Margin="0,6,0,0" Style="{StaticResource FieldValueStyle}" TextWrapping="Wrap" Text="{Binding SelectedActionNoteText}" />
                                <Border Margin="0,18,0,0" Height="180" Background="{DynamicResource MapSurfaceBrush}" BorderBrush="{DynamicResource PanelCardBorderBrush}" BorderThickness="1" CornerRadius="{StaticResource InnerCardCornerRadius}">
                                    <Grid>
                                        <Image Stretch="UniformToFill" Source="{Binding SelectedImageUri}">
                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasSelectedImage}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="当前记录没有可展示的截图证据">
                                            <TextBlock.Style>
                                                <Style BasedOn="{StaticResource SectionHintStyle}" TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasSelectedImage}" Value="True"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource PanelCardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="派单 / 复检 / 销警" />
                                <TextBlock Margin="0,10,0,0" Style="{StaticResource SectionHintStyle}" TextWrapping="Wrap" Text="动作全部写回本地闭环状态，并联动 AI 告警本地工作流，不推送真实外部平台。" />
                                <TextBlock Margin="0,16,0,6" Style="{StaticResource FieldLabelStyle}" Text="派单状态" />
                                <TextBlock Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedDispatchStatusText}" />
                                <TextBlock Margin="0,10,0,6" Style="{StaticResource FieldLabelStyle}" Text="派单创建 / 渠道" />
                                <TextBlock Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedDispatchCreatedText}" />
                                <TextBlock Margin="0,6,0,0" Style="{StaticResource FieldValueStyle}" TextWrapping="Wrap" Text="{Binding SelectedDispatchChannelsText}" />
                                <TextBlock Margin="0,10,0,6" Style="{StaticResource FieldLabelStyle}" Text="最新复检 / 销警轨迹" />
                                <TextBlock Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedLatestRecheckText}" />
                                <TextBlock Margin="0,6,0,0" Style="{StaticResource FieldValueStyle}" TextWrapping="Wrap" Text="{Binding SelectedClearTrailText}" />
                                <TextBlock Margin="0,16,0,6" Style="{StaticResource FieldLabelStyle}" Text="操作人" />
                                <TextBlock Margin="0,14,0,6" Style="{StaticResource FieldLabelStyle}" Text="任务调度状态" />
                                <TextBlock Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedTaskStatusText}" />
                                <TextBlock Margin="0,6,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedTaskEnabledText}" />
                                <TextBlock Margin="0,6,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedTaskNextRunText, StringFormat=下次执行：{0}}" />
                                <TextBlock Margin="0,6,0,0" Style="{StaticResource SectionHintStyle}" TextWrapping="Wrap" Text="{Binding SelectedTaskRuleText}" />
                                <TextBlock Margin="0,6,0,0" Style="{StaticResource SectionHintStyle}" TextWrapping="Wrap" Text="{Binding SelectedTaskLatestResultText}" />
                                <TextBox IsEnabled="{Binding HasSelectedRecord}" Text="{Binding OperatorName, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="0,14,0,6" Style="{StaticResource FieldLabelStyle}" Text="操作备注" />
                                <TextBox Height="84" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" IsEnabled="{Binding HasSelectedRecord}" TextWrapping="Wrap" Text="{Binding ActionNote, UpdateSourceTrigger=PropertyChanged}" />
                                <WrapPanel Margin="0,18,0,0">
                                    <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding MarkDispatchedCommand}" IsEnabled="{Binding CanMarkDispatched}" Content="标记已派单" />
                                    <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding RunRecheckCommand}" IsEnabled="{Binding CanRunRecheck}" Content="执行单点复检" />
                                    <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding ClearRecoveredCommand}" IsEnabled="{Binding CanClearRecovered}" Content="人工确认恢复" />
                                    <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding CloseRecordCommand}" IsEnabled="{Binding CanCloseRecord}" Content="关闭记录" />
                                    <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding CloseFalsePositiveCommand}" IsEnabled="{Binding CanCloseFalsePositive}" Content="误报关闭" />
                                    <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding ResetActionDraftCommand}" IsEnabled="{Binding HasSelectedRecord}" Content="重置表单" />
                                </WrapPanel>
                                <TextBlock Margin="0,18,0,6" Style="{StaticResource FieldLabelStyle}" Text="复检记录" />
                                <ItemsControl ItemsSource="{Binding SelectedRecord.RecheckRecords}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,10" Padding="12" Background="{DynamicResource MetricTileBackgroundBrush}" BorderBrush="{DynamicResource PanelCardBorderBrush}" BorderThickness="1" CornerRadius="{StaticResource InnerCardCornerRadius}">
                                                <StackPanel>
                                                    <DockPanel>
                                                        <TextBlock FontWeight="SemiBold" Text="{Binding OutcomeText}" />
                                                        <TextBlock DockPanel.Dock="Right" Style="{StaticResource SectionHintStyle}" Text="{Binding TriggeredAtText}" />
                                                    </DockPanel>
                                                    <TextBlock Margin="0,6,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding ResultSummaryText}" />
                                                    <TextBlock Margin="0,6,0,0" Style="{StaticResource SectionHintStyle}" TextWrapping="Wrap" Text="{Binding FailureReason}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Margin="0,18,0,6" Style="{StaticResource FieldLabelStyle}" Text="销警 / 关闭记录" />
                                <ItemsControl ItemsSource="{Binding SelectedRecord.ClearRecords}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,10" Padding="12" Background="{DynamicResource MetricTileBackgroundBrush}" BorderBrush="{DynamicResource PanelCardBorderBrush}" BorderThickness="1" CornerRadius="{StaticResource InnerCardCornerRadius}">
                                                <StackPanel>
                                                    <DockPanel>
                                                        <TextBlock FontWeight="SemiBold" Text="{Binding ActionTypeText}" />
                                                        <TextBlock DockPanel.Dock="Right" Style="{StaticResource SectionHintStyle}" Text="{Binding PerformedAtText}" />
                                                    </DockPanel>
                                                    <TextBlock Margin="0,6,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding StatusAfterText}" />
                                                    <TextBlock Margin="0,6,0,0" Style="{StaticResource SectionHintStyle}" TextWrapping="Wrap" Text="{Binding NoteText}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                        <sharedPages:DeviceMediaReviewPanelView DataContext="{Binding MediaReview}" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
