<UserControl x:Class="TylinkInspection.UI.Views.Pages.ReportCenterPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             xmlns:viewModels="clr-namespace:TylinkInspection.UI.ViewModels">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="RangeOptionButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{DynamicResource MetricTileBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Padding="14,10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource InnerCardCornerRadius}">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource FilterBadgeBackgroundBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource TonePrimaryBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="MetricCardTemplate">
            <Border Margin="0,0,12,12"
                    Padding="14"
                    Background="{DynamicResource MetricTileBackgroundBrush}"
                    BorderBrush="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource InnerCardCornerRadius}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding Label}" />
                    <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                        <TextBlock FontSize="{StaticResource FontSizeMetric}" FontWeight="Bold" Text="{Binding Value}" />
                        <TextBlock Margin="6,10,0,0" Foreground="{DynamicResource SecondaryTextBrush}" Text="{Binding Unit}" />
                    </StackPanel>
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}"
                               Text="{Binding DeltaText}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="VisualItemTemplate" DataType="{x:Type viewModels:ReportVisualItemViewModel}">
            <Border Margin="0,0,0,10"
                    Padding="12"
                    Background="{DynamicResource MetricTileBackgroundBrush}"
                    BorderBrush="{DynamicResource PanelCardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource InnerCardCornerRadius}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="{Binding Label}" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource SectionHintStyle}"
                                   TextWrapping="Wrap"
                                   Text="{Binding DetailText}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="18,0,0,0" HorizontalAlignment="Right">
                        <TextBlock HorizontalAlignment="Right"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Text="{Binding ValueText}" />
                        <Border Margin="0,8,0,0"
                                Width="{Binding BarWidth}"
                                Height="6"
                                HorizontalAlignment="Right"
                                Background="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}"
                                CornerRadius="3" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,4">
            <Border Style="{StaticResource PanelCardStyle}">
                <StackPanel>
                    <DockPanel>
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{Binding PageTitle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource SectionHintStyle}"
                                       TextWrapping="Wrap"
                                       Text="{Binding PageSubtitle}" />
                            <TextBlock Margin="0,14,0,0"
                                       Style="{StaticResource FieldValueStyle}"
                                       Text="{Binding CurrentSchemeText}" />
                            <TextBlock Margin="0,6,0,0"
                                       Style="{StaticResource SectionHintStyle}"
                                       Text="{Binding ActiveRangeText}" />
                            <TextBlock Margin="0,6,0,0"
                                       Style="{StaticResource SectionHintStyle}"
                                       Text="{Binding StatusText}" />
                            <Border Margin="0,10,0,0"
                                    Padding="10"
                                    Background="{DynamicResource FilterBadgeBackgroundBrush}"
                                    BorderBrush="{DynamicResource ToneDangerBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource InnerCardCornerRadius}"
                                    Visibility="{Binding HasWarning, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Foreground="{DynamicResource ToneDangerBrush}"
                                           TextWrapping="Wrap"
                                           Text="{Binding WarningText}" />
                            </Border>
                        </StackPanel>

                        <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                            <Border Style="{StaticResource MiniBadgeStyle}"
                                    Background="{DynamicResource FilterBadgeBackgroundBrush}"
                                    BorderBrush="{Binding StatusBadgeAccentResourceKey, Converter={StaticResource ResourceLookupConverter}}">
                                <TextBlock Text="{Binding StatusBadgeText}" />
                            </Border>
                            <Border Margin="0,10,0,0"
                                    Style="{StaticResource MiniBadgeStyle}"
                                    Background="{DynamicResource FilterBadgeBackgroundBrush}">
                                <TextBlock Text="{Binding ReportKindText}" />
                            </Border>
                            <Border Margin="0,10,0,0"
                                    Style="{StaticResource MiniBadgeStyle}"
                                    Background="{DynamicResource FilterBadgeBackgroundBrush}">
                                <TextBlock Text="{Binding LastUpdatedText}" />
                            </Border>
                        </StackPanel>
                    </DockPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PanelCardStyle}">
                <StackPanel>
                    <DockPanel>
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="统计周期" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource SectionHintStyle}"
                                       Text="支持日报、周报、月报与自定义时间范围，所有统计统一按本地数据沉淀口径过滤。" />
                        </StackPanel>
                        <Button DockPanel.Dock="Right"
                                Style="{StaticResource ActionButtonStyle}"
                                Command="{Binding RefreshCommand}"
                                IsEnabled="{Binding CanRefresh}"
                                Content="刷新统计" />
                    </DockPanel>

                    <ItemsControl Margin="0,18,0,0" ItemsSource="{Binding TimeRangeOptions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource RangeOptionButtonStyle}"
                                        Command="{Binding DataContext.SelectTimeRangeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <StackPanel Width="120">
                                        <DockPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                                            <Border DockPanel.Dock="Right"
                                                    Style="{StaticResource MiniBadgeStyle}"
                                                    Background="{DynamicResource FilterBadgeBackgroundBrush}">
                                                <TextBlock Text="{Binding Badge}" />
                                            </Border>
                                        </DockPanel>
                                        <TextBlock Margin="0,6,0,0"
                                                   Style="{StaticResource SectionHintStyle}"
                                                   Text="{Binding Subtitle}" />
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid Margin="0,6,0,0"
                          Visibility="{Binding IsCustomRangeSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="开始日期" />
                            <DatePicker Margin="0,6,0,0" SelectedDate="{Binding CustomStartDate}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="结束日期" />
                            <DatePicker Margin="0,6,0,0" SelectedDate="{Binding CustomEndDate}" />
                        </StackPanel>
                        <Button Grid.Column="2"
                                Margin="0,24,12,0"
                                Style="{StaticResource ActionButtonStyle}"
                                Command="{Binding ApplyCustomRangeCommand}"
                                Content="应用区间" />
                        <TextBlock Grid.Column="3"
                                   Margin="0,30,0,0"
                                   Style="{StaticResource SectionHintStyle}"
                                   TextWrapping="Wrap"
                                   Text="自定义结束日期按当天 24:00 前的本地沉淀记录纳入统计。" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PanelCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="顶部统计总览" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource SectionHintStyle}"
                               Text="面向领导视图和后续导出使用，先固定沉淀巡检、复核、闭环与复检的统一总览口径。" />
                    <ItemsControl Margin="0,18,0,0" ItemsSource="{Binding OverviewCards}" ItemTemplate="{StaticResource MetricCardTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <primitives:UniformGrid Columns="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PanelCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="巡检统计区" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource SectionHintStyle}"
                               TextWrapping="Wrap"
                               Text="{Binding InspectionSummaryText}" />
                    <ItemsControl Margin="0,18,0,0" ItemsSource="{Binding InspectionCards}" ItemTemplate="{StaticResource MetricCardTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <primitives:UniformGrid Columns="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Margin="0,0,12,0"
                                Padding="14"
                                Background="{DynamicResource FilterBadgeBackgroundBrush}"
                                BorderBrush="{DynamicResource PanelCardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource InnerCardCornerRadius}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="播放等级分布" />
                                <ItemsControl Margin="0,12,0,0"
                                              ItemsSource="{Binding InspectionGradeItems}"
                                              ItemTemplate="{StaticResource VisualItemTemplate}" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1"
                                Margin="12,0,0,0"
                                Padding="14"
                                Background="{DynamicResource FilterBadgeBackgroundBrush}"
                                BorderBrush="{DynamicResource PanelCardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource InnerCardCornerRadius}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="周期趋势" />
                                <ItemsControl Margin="0,12,0,0"
                                              ItemsSource="{Binding InspectionTrendItems}"
                                              ItemTemplate="{StaticResource VisualItemTemplate}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PanelCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="复核统计区" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource SectionHintStyle}"
                               TextWrapping="Wrap"
                               Text="{Binding ReviewSummaryText}" />
                    <ItemsControl Margin="0,18,0,0" ItemsSource="{Binding ReviewCards}" ItemTemplate="{StaticResource MetricCardTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <primitives:UniformGrid Columns="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Margin="0,0,12,0"
                                Padding="14"
                                Background="{DynamicResource FilterBadgeBackgroundBrush}"
                                BorderBrush="{DynamicResource PanelCardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource InnerCardCornerRadius}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="复核结论分布" />
                                <ItemsControl Margin="0,12,0,0"
                                              ItemsSource="{Binding ReviewConclusionItems}"
                                              ItemTemplate="{StaticResource VisualItemTemplate}" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1"
                                Margin="12,0,0,0"
                                Padding="14"
                                Background="{DynamicResource FilterBadgeBackgroundBrush}"
                                BorderBrush="{DynamicResource PanelCardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource InnerCardCornerRadius}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="复核来源分布" />
                                <ItemsControl Margin="0,12,0,0"
                                              ItemsSource="{Binding ReviewSourceItems}"
                                              ItemTemplate="{StaticResource VisualItemTemplate}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                    <Border Margin="0,12,0,0"
                            Padding="14"
                            Background="{DynamicResource FilterBadgeBackgroundBrush}"
                            BorderBrush="{DynamicResource PanelCardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource InnerCardCornerRadius}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="复核周期趋势" />
                            <ItemsControl Margin="0,12,0,0"
                                          ItemsSource="{Binding ReviewTrendItems}"
                                          ItemTemplate="{StaticResource VisualItemTemplate}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PanelCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="闭环统计区" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource SectionHintStyle}"
                               TextWrapping="Wrap"
                               Text="{Binding FaultSummaryText}" />
                    <ItemsControl Margin="0,18,0,0" ItemsSource="{Binding FaultCards}" ItemTemplate="{StaticResource MetricCardTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <primitives:UniformGrid Columns="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Margin="0,0,12,0"
                                Padding="14"
                                Background="{DynamicResource FilterBadgeBackgroundBrush}"
                                BorderBrush="{DynamicResource PanelCardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource InnerCardCornerRadius}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="闭环状态分布" />
                                <ItemsControl Margin="0,12,0,0"
                                              ItemsSource="{Binding FaultStatusItems}"
                                              ItemTemplate="{StaticResource VisualItemTemplate}" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1"
                                Margin="12,0,0,0"
                                Padding="14"
                                Background="{DynamicResource FilterBadgeBackgroundBrush}"
                                BorderBrush="{DynamicResource PanelCardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource InnerCardCornerRadius}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="闭环来源分布" />
                                <ItemsControl Margin="0,12,0,0"
                                              ItemsSource="{Binding FaultSourceItems}"
                                              ItemTemplate="{StaticResource VisualItemTemplate}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                    <Border Margin="0,12,0,0"
                            Padding="14"
                            Background="{DynamicResource FilterBadgeBackgroundBrush}"
                            BorderBrush="{DynamicResource PanelCardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource InnerCardCornerRadius}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="闭环周期趋势" />
                            <ItemsControl Margin="0,12,0,0"
                                          ItemsSource="{Binding FaultTrendItems}"
                                          ItemTemplate="{StaticResource VisualItemTemplate}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PanelCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="复检统计区" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource SectionHintStyle}"
                               TextWrapping="Wrap"
                               Text="{Binding RecheckSummaryText}" />
                    <ItemsControl Margin="0,18,0,0" ItemsSource="{Binding RecheckCards}" ItemTemplate="{StaticResource MetricCardTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <primitives:UniformGrid Columns="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Margin="0,0,12,0"
                                Padding="14"
                                Background="{DynamicResource FilterBadgeBackgroundBrush}"
                                BorderBrush="{DynamicResource PanelCardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource InnerCardCornerRadius}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="执行结果分布" />
                                <ItemsControl Margin="0,12,0,0"
                                              ItemsSource="{Binding RecheckOutcomeItems}"
                                              ItemTemplate="{StaticResource VisualItemTemplate}" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1"
                                Margin="12,0,0,0"
                                Padding="14"
                                Background="{DynamicResource FilterBadgeBackgroundBrush}"
                                BorderBrush="{DynamicResource PanelCardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource InnerCardCornerRadius}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="触发方式分布" />
                                <ItemsControl Margin="0,12,0,0"
                                              ItemsSource="{Binding RecheckTriggerItems}"
                                              ItemTemplate="{StaticResource VisualItemTemplate}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                    <Border Margin="0,12,0,0"
                            Padding="14"
                            Background="{DynamicResource FilterBadgeBackgroundBrush}"
                            BorderBrush="{DynamicResource PanelCardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource InnerCardCornerRadius}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="复检周期趋势" />
                            <ItemsControl Margin="0,12,0,0"
                                          ItemsSource="{Binding RecheckTrendItems}"
                                          ItemTemplate="{StaticResource VisualItemTemplate}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PanelCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="导出预留与当前边界" />
                    <TextBlock Margin="0,12,0,0"
                               Style="{StaticResource FieldValueStyle}"
                               TextWrapping="Wrap"
                               Text="{Binding ExportReserveText}" />
                    <TextBlock Margin="0,12,0,0"
                               Style="{StaticResource SectionHintStyle}"
                               TextWrapping="Wrap"
                               Text="{Binding BoundaryText}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
