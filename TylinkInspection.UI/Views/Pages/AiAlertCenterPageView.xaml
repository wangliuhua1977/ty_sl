<UserControl x:Class="TylinkInspection.UI.Views.Pages.AiAlertCenterPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,4">
            <Border Style="{StaticResource PanelCardStyle}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{Binding PageTitle}" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource SectionHintStyle}"
                                   TextWrapping="Wrap"
                                   Text="{Binding PageSubtitle}" />
                    </StackPanel>
                    <Border DockPanel.Dock="Right"
                            Style="{StaticResource MiniBadgeStyle}"
                            Background="{DynamicResource FilterBadgeBackgroundBrush}">
                        <TextBlock Text="AI ALERT FLOW" />
                    </Border>
                </DockPanel>
            </Border>

            <ItemsControl ItemsSource="{Binding SummaryCards}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <primitives:UniformGrid Columns="4" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,16,16"
                                Padding="16"
                                Background="{DynamicResource MetricTileBackgroundBrush}"
                                BorderBrush="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource InnerCardCornerRadius}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding Label}" />
                                <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                    <TextBlock FontSize="{StaticResource FontSizeMetric}" FontWeight="Bold" Text="{Binding Value}" />
                                    <TextBlock Margin="6,10,0,0" Foreground="{DynamicResource SecondaryTextBrush}" Text="{Binding Unit}" />
                                </StackPanel>
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}"
                                           Text="{Binding DeltaText}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Style="{StaticResource PanelCardStyle}">
                <StackPanel>
                    <WrapPanel>
                        <TextBlock Style="{StaticResource FilterLabelStyle}" Text="时间范围" />
                        <ComboBox Width="140"
                                  Style="{StaticResource FilterComboBoxStyle}"
                                  ItemsSource="{Binding TimeRangeOptions}"
                                  SelectedItem="{Binding SelectedTimeRange}" />

                        <TextBlock Style="{StaticResource FilterLabelStyle}" Text="本地状态" />
                        <ComboBox Width="140"
                                  Style="{StaticResource FilterComboBoxStyle}"
                                  ItemsSource="{Binding WorkflowOptions}"
                                  SelectedItem="{Binding SelectedWorkflow}" />

                        <TextBlock Style="{StaticResource FilterLabelStyle}" Text="告警来源" />
                        <ComboBox Width="170"
                                  Style="{StaticResource FilterComboBoxStyle}"
                                  ItemsSource="{Binding AlertSourceOptions}"
                                  SelectedItem="{Binding SelectedAlertSource}" />

                        <TextBlock Style="{StaticResource FilterLabelStyle}" Text="告警类型" />
                        <ComboBox Width="180"
                                  Style="{StaticResource FilterComboBoxStyle}"
                                  ItemsSource="{Binding AlertTypeOptions}"
                                  SelectedItem="{Binding SelectedAlertType}" />

                        <TextBlock Style="{StaticResource FilterLabelStyle}" Text="设备编码" />
                        <TextBox Width="180"
                                 Style="{StaticResource FilterTextBoxStyle}"
                                 Text="{Binding DeviceCode, UpdateSourceTrigger=PropertyChanged}" />

                        <Button Style="{StaticResource ActionButtonStyle}"
                                Command="{Binding SearchCommand}"
                                Content="执行筛选" />
                        <Button Style="{StaticResource ActionButtonStyle}"
                                Command="{Binding RefreshCommand}"
                                Content="刷新列表" />
                        <Button Style="{StaticResource ActionButtonStyle}"
                                Command="{Binding ClearFilterCommand}"
                                Content="清空条件" />
                    </WrapPanel>

                    <TextBlock Margin="0,14,0,0"
                               Style="{StaticResource SectionHintStyle}"
                               Text="{Binding ListStatusText}" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{DynamicResource ToneDangerBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding ListErrorText}" />
                </StackPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="380" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource PanelCardStyle}" Margin="0,0,18,0">
                    <DockPanel>
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="AI告警列表" />
                            <TextBlock Margin="0,8,0,18"
                                       Style="{StaticResource SectionHintStyle}"
                                       Text="真实数据驱动，支持筛选、刷新和滚动分页去重续翻。" />
                        </StackPanel>

                        <Button DockPanel.Dock="Bottom"
                                Margin="0,18,0,0"
                                Style="{StaticResource ActionButtonStyle}"
                                Command="{Binding LoadMoreCommand}"
                                Content="{Binding LoadMoreButtonText}" />

                        <ListBox ItemsSource="{Binding AlertItems}"
                                 SelectedItem="{Binding SelectedAlert}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ListItemCardStyle}"
                                            BorderBrush="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}">
                                        <StackPanel>
                                            <DockPanel>
                                                <TextBlock FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           Text="{Binding DeviceName}" />
                                                <Border DockPanel.Dock="Right"
                                                        Style="{StaticResource StatusBadgeBorderStyle}"
                                                        BorderBrush="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}">
                                                    <TextBlock Foreground="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}"
                                                               Text="{Binding WorkflowStatus}" />
                                                </Border>
                                            </DockPanel>
                                            <TextBlock Margin="0,10,0,0"
                                                       Style="{StaticResource FieldValueStyle}"
                                                       Text="{Binding AlertTypeName}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       Text="{Binding DeviceCode}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Style="{StaticResource SectionHintStyle}"
                                                       Text="{Binding AlertSourceName}" />
                                            <TextBlock Margin="0,8,0,0"
                                                       TextWrapping="Wrap"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       Text="{Binding Summary}" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Style="{StaticResource SectionHintStyle}"
                                                       Text="{Binding CreateTime, StringFormat='告警时间 {0:MM-dd HH:mm:ss}'}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource PanelCardStyle}" Margin="0,0,18,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="关联普通设备告警" />
                        <TextBlock Margin="0,8,0,12"
                                   Style="{StaticResource SectionHintStyle}"
                                   Text="{Binding RelatedAlarmStatusText}" />
                        <TextBlock Margin="0,0,0,18"
                                   Foreground="{DynamicResource ToneDangerBrush}"
                                   TextWrapping="Wrap"
                                   Text="{Binding RelatedAlarmErrorText}" />

                        <ItemsControl ItemsSource="{Binding RelatedDeviceAlarms}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ListItemCardStyle}"
                                            BorderBrush="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}">
                                        <StackPanel>
                                            <DockPanel>
                                                <TextBlock FontWeight="SemiBold" Text="{Binding AlarmTypeName}" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           Foreground="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}"
                                                           Text="{Binding SeverityOrStatusText}" />
                                            </DockPanel>
                                            <TextBlock Margin="0,8,0,0"
                                                       Style="{StaticResource FieldValueStyle}"
                                                       Text="{Binding DeviceName}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       Text="{Binding DeviceCode}" />
                                            <TextBlock Margin="0,8,0,0"
                                                       TextWrapping="Wrap"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       Text="{Binding Content}" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Style="{StaticResource SectionHintStyle}"
                                                       Text="{Binding CreateTime, StringFormat='告警时间 {0:MM-dd HH:mm:ss}'}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource PanelCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="告警详情" />
                        <TextBlock Margin="0,8,0,18"
                                   Style="{StaticResource SectionHintStyle}"
                                   Text="保留基础详情字段和本地复核备注，后续可继续接入 AI 告警详情、截图和恢复销警。" />

                        <Border Style="{StaticResource StatusBadgeBorderStyle}"
                                BorderBrush="{Binding SelectedAlertAccentResourceKey, Converter={StaticResource ResourceLookupConverter}}"
                                HorizontalAlignment="Left">
                            <TextBlock Foreground="{Binding SelectedAlertAccentResourceKey, Converter={StaticResource ResourceLookupConverter}}"
                                       Text="{Binding SelectedAlertWorkflowText}" />
                        </Border>

                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="MsgId" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedAlertDetail.MsgId, TargetNullValue=--}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,10,0,4" Style="{StaticResource FieldLabelStyle}" Text="设备编码" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedAlertDetail.DeviceCode, TargetNullValue=--}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,10,0,4" Style="{StaticResource FieldLabelStyle}" Text="设备名称" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedAlertDetail.DeviceName, TargetNullValue=--}" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,10,0,4" Style="{StaticResource FieldLabelStyle}" Text="告警类型" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedAlertDetail.AlertTypeName, TargetNullValue=--}" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,10,0,4" Style="{StaticResource FieldLabelStyle}" Text="告警来源" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedAlertDetail.AlertSourceName, TargetNullValue=--}" />

                            <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,10,0,4" Style="{StaticResource FieldLabelStyle}" Text="平台状态" />
                            <TextBlock Grid.Row="5" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedAlertPlatformStatusText}" />
                        </Grid>

                        <TextBlock Margin="0,20,0,6" Style="{StaticResource FieldLabelStyle}" Text="摘要" />
                        <TextBlock Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedAlertSummaryText}" />

                        <TextBlock Margin="0,14,0,6" Style="{StaticResource FieldLabelStyle}" Text="时间" />
                        <TextBlock Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedAlertTimeText}" />

                        <TextBlock Margin="0,14,0,6" Style="{StaticResource FieldLabelStyle}" Text="本地复核备注" />
                        <TextBox Height="96"
                                 Margin="0,0,0,18"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Style="{StaticResource FilterTextBoxStyle}"
                                 Text="{Binding ReviewNote, UpdateSourceTrigger=PropertyChanged}" />

                        <WrapPanel>
                            <Button Style="{StaticResource ActionButtonStyle}"
                                    Command="{Binding UpdateWorkflowCommand}"
                                    CommandParameter="待确认"
                                    Content="转待确认" />
                            <Button Style="{StaticResource ActionButtonStyle}"
                                    Command="{Binding UpdateWorkflowCommand}"
                                    CommandParameter="已确认"
                                    Content="确认告警" />
                            <Button Style="{StaticResource ActionButtonStyle}"
                                    Command="{Binding UpdateWorkflowCommand}"
                                    CommandParameter="已忽略"
                                    Content="忽略告警" />
                            <Button Style="{StaticResource ActionButtonStyle}"
                                    Command="{Binding UpdateWorkflowCommand}"
                                    CommandParameter="已派单"
                                    Content="标记派单" />
                            <Button Style="{StaticResource ActionButtonStyle}"
                                    Command="{Binding UpdateWorkflowCommand}"
                                    CommandParameter="已恢复"
                                    Content="标记恢复" />
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
