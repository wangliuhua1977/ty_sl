<UserControl x:Class="TylinkInspection.UI.Views.Pages.Shared.DeviceMediaReviewPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:shared="clr-namespace:TylinkInspection.UI.Views.Pages.Shared"
             mc:Ignorable="d">
    <StackPanel>
        <Border Margin="0,22,0,0"
                Padding="16"
                Background="{DynamicResource MetricTileBackgroundBrush}"
                BorderBrush="{DynamicResource ToneInfoBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource InnerCardCornerRadius}">
            <StackPanel>
                <DockPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="视频复核" />
                    <WrapPanel DockPanel.Dock="Right">
                        <Border Margin="0,0,8,0"
                                Style="{StaticResource MiniBadgeStyle}"
                                Background="{DynamicResource FilterBadgeBackgroundBrush}">
                            <TextBlock Text="{Binding CurrentReviewTargetText}" />
                        </Border>
                        <Border Style="{StaticResource MiniBadgeStyle}"
                                Background="{DynamicResource FilterBadgeBackgroundBrush}">
                            <TextBlock Text="{Binding PlayerImplementationText}" />
                        </Border>
                    </WrapPanel>
                </DockPanel>

                <TextBlock Margin="0,10,0,0"
                           Style="{StaticResource SectionHintStyle}"
                           Text="{Binding LiveReviewStatusText}"
                           TextWrapping="Wrap" />
                <TextBlock Margin="0,8,0,0"
                           Foreground="{DynamicResource ToneDangerBrush}"
                           Text="{Binding LiveReviewAlertText}"
                           TextWrapping="Wrap" />

                <shared:LightPlaybackHostView Height="220" Margin="0,16,0,0" />

                <WrapPanel Margin="0,16,0,0">
                    <Button Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding PrepareLiveReviewCommand}"
                            IsEnabled="{Binding CanPrepareLiveReview}"
                            Content="{Binding LoadLiveReviewButtonText}" />
                    <Button Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding RefreshLiveReviewCommand}"
                            IsEnabled="{Binding CanPrepareLiveReview}"
                            Content="刷新直播地址" />
                </WrapPanel>

                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="96" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="当前模式" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource FieldValueStyle}" Text="{Binding CurrentReviewTargetText}" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource FieldLabelStyle}" Text="复核对象" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding CurrentReviewSubjectText}" TextWrapping="Wrap" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource FieldLabelStyle}" Text="当前协议" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding ActiveProtocolText}" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource FieldLabelStyle}" Text="地址状态" />
                    <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding ActiveExpireTimeText}" />

                    <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource FieldLabelStyle}" Text="视频编码" />
                    <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding VideoEncodingText}" />

                    <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource FieldLabelStyle}" Text="当前地址" />
                    <TextBlock Grid.Row="5" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding ActiveUrlText}" TextWrapping="Wrap" />
                </Grid>
            </StackPanel>
        </Border>

        <Border Margin="0,22,0,0"
                Padding="16"
                Background="{DynamicResource MetricTileBackgroundBrush}"
                BorderBrush="{DynamicResource TonePrimaryBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource InnerCardCornerRadius}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="首帧结果 / 最近截图" />

                <Grid Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="96" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="最近复核" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource FieldValueStyle}" Text="{Binding LatestReviewResult.ReviewedAtText, TargetNullValue=--}" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource FieldLabelStyle}" Text="复核类型" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding LatestReviewResult.ReviewTargetText, TargetNullValue=--}" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource FieldLabelStyle}" Text="复核对象" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding LatestReviewResult.ReviewSubjectText, TargetNullValue=--}" TextWrapping="Wrap" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource FieldLabelStyle}" Text="首帧结论" />
                    <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding LatestReviewResult.ReviewOutcomeText, TargetNullValue=待复核}" />

                    <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource FieldLabelStyle}" Text="起播耗时" />
                    <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding LatestReviewResult.StartupDurationText, TargetNullValue=--}" />

                    <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource FieldLabelStyle}" Text="使用协议" />
                    <TextBlock Grid.Row="5" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding LatestReviewResult.UsedProtocol, TargetNullValue=--}" />

                    <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource FieldLabelStyle}" Text="是否回退" />
                    <TextBlock Grid.Row="6" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding LatestReviewResult.UsedFallback, StringFormat='{}{0}', TargetNullValue=--}" />

                    <TextBlock Grid.Row="7" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource FieldLabelStyle}" Text="失败原因" />
                    <TextBlock Grid.Row="7" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding LatestReviewResult.FailureReasonText, TargetNullValue=无}" TextWrapping="Wrap" />
                </Grid>

                <TextBlock Margin="0,18,0,6" Style="{StaticResource FieldLabelStyle}" Text="最近截图样本" />
                <TextBlock Style="{StaticResource FieldValueStyle}"
                           Text="{Binding LatestScreenshot.CapturedAtText, StringFormat='截图时间：{0}', TargetNullValue=截图时间：-}" />
                <TextBlock Margin="0,6,0,0"
                           Style="{StaticResource FieldValueStyle}"
                           Text="{Binding LatestScreenshot.ReviewTargetText, StringFormat='截图类型：{0}', TargetNullValue=截图类型：-}" />
                <TextBlock Margin="0,6,0,0"
                           Style="{StaticResource FieldValueStyle}"
                           Text="{Binding LatestScreenshot.Protocol, StringFormat='来源协议：{0}', TargetNullValue=来源协议：-}" />
                <TextBlock Margin="0,6,0,0"
                           Style="{StaticResource FieldValueStyle}"
                           Text="{Binding LatestScreenshot.ImagePath, StringFormat='本地路径：{0}', TargetNullValue=本地路径：-}"
                           TextWrapping="Wrap" />

                <Border Margin="0,14,0,0"
                        Background="{DynamicResource MapSurfaceBrush}"
                        BorderBrush="{DynamicResource PanelCardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource InnerCardCornerRadius}">
                    <Grid Height="132">
                        <Image Stretch="UniformToFill" Source="{Binding LatestScreenshot.ImagePath}">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasLatestScreenshot}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="当前尚未生成截图样本。">
                            <TextBlock.Style>
                                <Style BasedOn="{StaticResource SectionHintStyle}" TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasLatestScreenshot}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <Border Margin="0,22,0,0"
                Padding="16"
                Background="{DynamicResource MetricTileBackgroundBrush}"
                BorderBrush="{DynamicResource ToneFocusBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource InnerCardCornerRadius}">
            <StackPanel>
                <DockPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="最近回看" />
                    <WrapPanel DockPanel.Dock="Right">
                        <Button Style="{StaticResource ActionButtonStyle}"
                                Command="{Binding RefreshPlaybackFilesCommand}"
                                IsEnabled="{Binding CanRefreshPlaybackFiles}"
                                Content="刷新回看" />
                    </WrapPanel>
                </DockPanel>

                <TextBlock Margin="0,10,0,0"
                           Style="{StaticResource SectionHintStyle}"
                           Text="{Binding PlaybackFileStatusText}"
                           TextWrapping="Wrap" />
                <TextBlock Margin="0,8,0,0"
                           Foreground="{DynamicResource ToneDangerBrush}"
                           Text="{Binding PlaybackFileAlertText}"
                           TextWrapping="Wrap" />

                <ItemsControl Margin="0,14,0,0" ItemsSource="{Binding RecentPlaybackFiles}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,12"
                                    Padding="12"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource PanelCardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource InnerCardCornerRadius}">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="{Binding Name}" TextWrapping="Wrap" />
                                    <TextBlock Margin="0,6,0,0" Style="{StaticResource SectionHintStyle}" Text="{Binding CreateTimeText, StringFormat='创建时间：{0}'}" />
                                    <TextBlock Margin="0,4,0,0" Style="{StaticResource SectionHintStyle}" Text="{Binding FileType, StringFormat='文件类型：{0}'}" />
                                    <TextBlock Margin="0,4,0,0" Style="{StaticResource SectionHintStyle}" Text="{Binding IconUrlText, StringFormat='首帧图标：{0}'}" TextWrapping="Wrap" />
                                    <TextBlock Margin="0,4,0,0" Style="{StaticResource SectionHintStyle}" Text="{Binding StreamResolvedAtText, StringFormat='流化时间：{0}', TargetNullValue=流化时间：--}" />

                                    <WrapPanel Margin="0,10,0,0">
                                        <Button Style="{StaticResource ActionButtonStyle}"
                                                Command="{Binding DataContext.PlayPlaybackFileCommand, RelativeSource={RelativeSource AncestorType={x:Type shared:DeviceMediaReviewPanelView}}}"
                                                CommandParameter="{Binding}"
                                                IsEnabled="{Binding DataContext.CanPreparePlaybackReview, RelativeSource={RelativeSource AncestorType={x:Type shared:DeviceMediaReviewPanelView}}}"
                                                Content="回看复核" />
                                        <Button Style="{StaticResource ActionButtonStyle}"
                                                Command="{Binding DataContext.RefreshPlaybackStreamCommand, RelativeSource={RelativeSource AncestorType={x:Type shared:DeviceMediaReviewPanelView}}}"
                                                CommandParameter="{Binding}"
                                                IsEnabled="{Binding DataContext.CanPreparePlaybackReview, RelativeSource={RelativeSource AncestorType={x:Type shared:DeviceMediaReviewPanelView}}}"
                                                Content="刷新流化" />
                                    </WrapPanel>

                                    <TextBlock Margin="0,8,0,0"
                                               Style="{StaticResource SectionHintStyle}"
                                               Text="{Binding HlsStreamUrlText, StringFormat='HLS：{0}'}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,4,0,0"
                                               Style="{StaticResource SectionHintStyle}"
                                               Text="{Binding RtmpStreamUrlText, StringFormat='RTMP：{0}'}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,4,0,0"
                                               Style="{StaticResource SectionHintStyle}"
                                               Text="{Binding DownloadUrlText, StringFormat='下载地址：{0}'}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Style="{StaticResource SectionHintStyle}"
                           Text="当前阶段已接入云回看文件列表、HLS/RTMP 流化地址与下载地址扩展位。点击单条文件即可在当前详情区内进入回看复核，截图采样与首帧结果会沿用同一套沉淀结构。"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
