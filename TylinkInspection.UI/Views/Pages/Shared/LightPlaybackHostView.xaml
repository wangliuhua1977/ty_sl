<UserControl x:Class="TylinkInspection.UI.Views.Pages.Shared.LightPlaybackHostView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             Loaded="OnLoaded">
    <Border Background="{DynamicResource MapSurfaceBrush}"
            BorderBrush="{DynamicResource MapBorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource InnerCardCornerRadius}">
        <wv2:WebView2 x:Name="PlayerWebView"
                      DefaultBackgroundColor="Transparent" />
    </Border>
</UserControl>
