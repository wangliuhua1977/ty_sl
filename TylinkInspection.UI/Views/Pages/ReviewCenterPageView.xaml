<UserControl x:Class="TylinkInspection.UI.Views.Pages.ReviewCenterPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             xmlns:sharedPages="clr-namespace:TylinkInspection.UI.Views.Pages.Shared"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,4">
            <Border Style="{StaticResource PanelCardStyle}">
                <StackPanel>
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{Binding PageTitle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource SectionHintStyle}"
                                       TextWrapping="Wrap"
                                       Text="{Binding PageSubtitle}" />
                            <TextBlock Margin="0,12,0,0"
                                       Style="{StaticResource SectionHintStyle}"
                                       TextWrapping="Wrap"
                                       Text="{Binding StatusText}" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{DynamicResource ToneDangerBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding WarningText}" />
                        </StackPanel>

                        <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                            <Border Style="{StaticResource MiniBadgeStyle}"
                                    Background="{DynamicResource FilterBadgeBackgroundBrush}"
                                    BorderBrush="{Binding StatusBadgeAccentResourceKey, Converter={StaticResource ResourceLookupConverter}}">
                                <TextBlock Text="{Binding StatusBadgeText}" />
                            </Border>
                            <Border Margin="0,10,0,0"
                                    Style="{StaticResource MiniBadgeStyle}"
                                    Background="{DynamicResource FilterBadgeBackgroundBrush}">
                                <TextBlock Text="{Binding LastUpdatedText}" />
                            </Border>
                        </StackPanel>
                    </DockPanel>

                    <ItemsControl Margin="0,18,0,0" ItemsSource="{Binding SummaryCards}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <primitives:UniformGrid Columns="5" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,12,0"
                                        Padding="14"
                                        Background="{DynamicResource MetricTileBackgroundBrush}"
                                        BorderBrush="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource InnerCardCornerRadius}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding Label}" />
                                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                            <TextBlock FontSize="{StaticResource FontSizeMetric}" FontWeight="Bold" Text="{Binding Value}" />
                                            <TextBlock Margin="6,10,0,0"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       Text="{Binding Unit}" />
                                        </StackPanel>
                                        <TextBlock Margin="0,8,0,0"
                                                   Foreground="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}"
                                                   Text="{Binding DeltaText}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="420" />
                </Grid.ColumnDefinitions>

                <ScrollViewer Grid.Column="0" Margin="0,0,18,0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Style="{StaticResource PanelCardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="当前巡检方案" />
                                <TextBlock Margin="0,10,0,0"
                                           Style="{StaticResource FieldValueStyle}"
                                           Text="{Binding CurrentSchemeText}" />
                                <TextBlock Margin="0,8,0,0"
                                           Style="{StaticResource SectionHintStyle}"
                                           TextWrapping="Wrap"
                                           Text="{Binding SchemeSummaryText}" />

                                <TextBlock Margin="0,16,0,6"
                                           Style="{StaticResource FieldLabelStyle}"
                                           Text="方案切换" />
                                <ComboBox ItemsSource="{Binding SchemeItems}"
                                          SelectedItem="{Binding SelectedScheme}"
                                          DisplayMemberPath="Title" />
                                <TextBlock Margin="0,8,0,0"
                                           Style="{StaticResource SectionHintStyle}"
                                           TextWrapping="Wrap"
                                           Text="{Binding SelectedScheme.Subtitle}" />

                                <WrapPanel Margin="0,18,0,0">
                                    <Button Style="{StaticResource ActionButtonStyle}"
                                            Command="{Binding RefreshCommand}"
                                            IsEnabled="{Binding CanRefresh}"
                                            Content="刷新截图墙" />
                                    <Button Style="{StaticResource ActionButtonStyle}"
                                            Command="{Binding RefreshAiAlertsCommand}"
                                            IsEnabled="{Binding CanRefresh}"
                                            Content="刷新 AI 异常" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PanelCardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="截图墙视图与筛选" />
                                <ItemsControl Margin="0,16,0,0" ItemsSource="{Binding WallModeItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Margin="0,0,0,10"
                                                    Command="{Binding DataContext.SelectWallModeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource SelectionButtonStyle}">
                                                        <Setter Property="Margin" Value="0,0,0,10" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Tag" Value="Selected" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock FontSize="15" FontWeight="SemiBold" Text="{Binding Title}" />
                                                        <TextBlock Margin="0,4,0,0"
                                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                                   TextWrapping="Wrap"
                                                                   Text="{Binding Subtitle}" />
                                                    </StackPanel>
                                                    <Border Grid.Column="1"
                                                            Margin="12,0,0,0"
                                                            Style="{StaticResource MiniBadgeStyle}"
                                                            Background="{DynamicResource TaskCountBadgeBackgroundBrush}">
                                                        <TextBlock FontWeight="SemiBold" Text="{Binding Badge}" />
                                                    </Border>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <CheckBox Margin="0,8,0,0"
                                          IsChecked="{Binding PrioritizeFocused}"
                                          Content="重点点位优先" />
                                <CheckBox Margin="0,8,0,0"
                                          IsChecked="{Binding PrioritizeAbnormal}"
                                          Content="异常点位优先" />
                                <CheckBox Margin="0,8,0,0"
                                          IsChecked="{Binding PendingOnly}"
                                          Content="仅看待人工复核" />

                                <TextBlock Margin="0,14,0,0"
                                           Style="{StaticResource SectionHintStyle}"
                                           TextWrapping="Wrap"
                                           Text="{Binding CurrentWallDescription}" />
                                <TextBlock Margin="0,8,0,0"
                                           Style="{StaticResource SectionHintStyle}"
                                           TextWrapping="Wrap"
                                           Text="{Binding CurrentWallSummaryText}" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{DynamicResource ToneWarningBrush}"
                                           TextWrapping="Wrap"
                                           Text="{Binding SelectedFilterNoticeText}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PanelCardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="样本来源说明" />
                                <TextBlock Margin="0,10,0,0"
                                           Style="{StaticResource SectionHintStyle}"
                                           TextWrapping="Wrap"
                                           Text="当前截图墙统一汇总直播首帧截图、回看播放截图与 AI 画面异常证据图，只展示当前巡检范围方案内点位。" />
                                <TextBlock Margin="0,8,0,0"
                                           Style="{StaticResource SectionHintStyle}"
                                           TextWrapping="Wrap"
                                           Text="人工复核结果会本地持久化，并为后续派单、复检和故障闭环预留关联字段。" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Column="1" Style="{StaticResource PanelCardStyle}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="22,18,22,0">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{Binding CurrentWallTitle}" />
                                <TextBlock Margin="0,8,0,0"
                                           Style="{StaticResource SectionHintStyle}"
                                           TextWrapping="Wrap"
                                           Text="{Binding CurrentWallDescription}" />
                                <TextBlock Margin="0,8,0,0"
                                           Style="{StaticResource SectionHintStyle}"
                                           Text="{Binding CurrentWallSummaryText}" />
                            </StackPanel>

                            <Border DockPanel.Dock="Right"
                                    Style="{StaticResource MiniBadgeStyle}"
                                    Background="{DynamicResource FilterBadgeBackgroundBrush}">
                                <TextBlock Text="{Binding DisplayedEvidenceCount, StringFormat='当前 {0} 张'}" />
                            </Border>
                        </DockPanel>

                        <Grid Grid.Row="1" Margin="22,18,22,18">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"
                                       Text="{Binding WallPlaceholderText}">
                                <TextBlock.Style>
                                    <Style BasedOn="{StaticResource SectionHintStyle}" TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasWallPlaceholder}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ScrollViewer.Style>
                                    <Style TargetType="ScrollViewer">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasWallPlaceholder}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ScrollViewer.Style>

                                <ItemsControl ItemsSource="{Binding DisplayedEvidenceCards}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Width="248"
                                                    Margin="0,0,16,16"
                                                    Padding="0"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Command="{Binding DataContext.SelectEvidenceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Border Padding="12"
                                                        Background="{DynamicResource MetricTileBackgroundBrush}"
                                                        BorderBrush="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}"
                                                        BorderThickness="1"
                                                        CornerRadius="{StaticResource InnerCardCornerRadius}">
                                                    <StackPanel>
                                                        <Border Height="136"
                                                                Background="{DynamicResource MapSurfaceBrush}"
                                                                BorderBrush="{DynamicResource PanelCardBorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="{StaticResource InnerCardCornerRadius}">
                                                            <Grid>
                                                                <Image Stretch="UniformToFill" Source="{Binding ImageUri}">
                                                                    <Image.Style>
                                                                        <Style TargetType="Image">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding HasImageUri}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Image.Style>
                                                                </Image>
                                                                <TextBlock HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Text="暂无可用截图预览">
                                                                    <TextBlock.Style>
                                                                        <Style BasedOn="{StaticResource SectionHintStyle}" TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding HasImageUri}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Grid>
                                                        </Border>

                                                        <TextBlock Margin="0,12,0,0"
                                                                   FontSize="15"
                                                                   FontWeight="SemiBold"
                                                                   TextWrapping="Wrap"
                                                                   Text="{Binding DeviceName}" />
                                                        <TextBlock Margin="0,6,0,0"
                                                                   Style="{StaticResource SectionHintStyle}"
                                                                   TextWrapping="Wrap"
                                                                   Text="{Binding RegionText}" />

                                                        <WrapPanel Margin="0,10,0,0">
                                                            <Border Style="{StaticResource MiniBadgeStyle}"
                                                                    Background="{DynamicResource FilterBadgeBackgroundBrush}"
                                                                    BorderBrush="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}">
                                                                <TextBlock Text="{Binding SourceText}" />
                                                            </Border>
                                                            <Border Style="{StaticResource MiniBadgeStyle}"
                                                                    Background="{DynamicResource FilterBadgeBackgroundBrush}">
                                                                <TextBlock Text="{Binding AbnormalTagText}" />
                                                            </Border>
                                                            <Border Style="{StaticResource MiniBadgeStyle}"
                                                                    Background="{DynamicResource FilterBadgeBackgroundBrush}">
                                                                <TextBlock Text="{Binding ManualConclusionText}" />
                                                            </Border>
                                                        </WrapPanel>

                                                        <TextBlock Margin="0,10,0,0"
                                                                   Style="{StaticResource FieldValueStyle}"
                                                                   Text="{Binding CapturedAtText}" />
                                                        <TextBlock Margin="0,6,0,0"
                                                                   Style="{StaticResource SectionHintStyle}"
                                                                   Text="{Binding PlaybackGradeText}" />
                                                        <TextBlock Margin="0,8,0,0"
                                                                   Style="{StaticResource SectionHintStyle}"
                                                                   TextWrapping="Wrap"
                                                                   Text="{Binding DetailText}" />
                                                    </StackPanel>
                                                </Border>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Column="2" Margin="18,0,0,0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Style="{StaticResource PanelCardStyle}">
                            <StackPanel>
                                <DockPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="单点人工复核面板" />
                                    <Border DockPanel.Dock="Right"
                                            Style="{StaticResource MiniBadgeStyle}"
                                            Background="{DynamicResource FilterBadgeBackgroundBrush}">
                                        <TextBlock Text="{Binding SelectedEvidenceManualConclusionText}" />
                                    </Border>
                                </DockPanel>

                                <TextBlock Margin="0,12,0,0"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Text="{Binding SelectedDeviceName}" />
                                <TextBlock Margin="0,6,0,0"
                                           Style="{StaticResource FieldValueStyle}"
                                           Text="{Binding SelectedDeviceCode}" />
                                <TextBlock Margin="0,10,0,0"
                                           Style="{StaticResource SectionHintStyle}"
                                           TextWrapping="Wrap"
                                           Text="{Binding SelectedContextHintText}" />
                                <Border Margin="0,14,0,0"
                                        Padding="14"
                                        Background="{DynamicResource MetricTileBackgroundBrush}"
                                        BorderBrush="{DynamicResource TonePrimaryBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource InnerCardCornerRadius}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="来源任务摘要" />
                                        <TextBlock Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SourceTaskNameText}" TextWrapping="Wrap" />
                                        <TextBlock Margin="0,4,0,0" Style="{StaticResource SectionHintStyle}" Text="{Binding SourceTaskTypeText}" TextWrapping="Wrap" />
                                        <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding SourceTaskExecutionText}" TextWrapping="Wrap" />
                                        <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding SourceTaskPlanText}" TextWrapping="Wrap" />
                                        <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding SourceTaskOriginText}" TextWrapping="Wrap" />
                                        <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding SourceTaskStatusText}" TextWrapping="Wrap" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Style="{StaticResource SectionHintStyle}"
                                                   Text="{Binding SourceTaskPointResultText}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Style="{StaticResource SectionHintStyle}"
                                                   Text="{Binding SourceTaskFailureText}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Foreground="{DynamicResource ToneWarningBrush}"
                                                   Text="{Binding TaskContextLocateText}"
                                                   TextWrapping="Wrap" />
                                        <Button Margin="0,10,0,0"
                                                Style="{StaticResource ActionButtonStyle}"
                                                Command="{Binding ReturnToSourceTaskCommand}"
                                                IsEnabled="{Binding CanReturnToSourceTask}"
                                                Content="返回来源任务" />
                                    </StackPanel>
                                </Border>
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{DynamicResource ToneWarningBrush}"
                                           TextWrapping="Wrap"
                                           Text="{Binding SelectedFilterNoticeText}" />

                                <Grid Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="108" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="点位状态" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedDeviceStatusText}" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource FieldLabelStyle}" Text="目录路径" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" TextWrapping="Wrap" Text="{Binding SelectedDeviceDirectoryText}" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource FieldLabelStyle}" Text="截图时间" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedEvidenceTimeText}" />

                                    <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource FieldLabelStyle}" Text="来源类型" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedEvidenceSourceText}" />

                                    <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource FieldLabelStyle}" Text="复核来源" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedReviewSourceText}" />

                                    <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource FieldLabelStyle}" Text="当前标签" />
                                    <TextBlock Grid.Row="5" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedEvidenceTagText}" />

                                    <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource FieldLabelStyle}" Text="播放等级" />
                                    <TextBlock Grid.Row="6" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedEvidencePlaybackGradeText}" />

                                    <TextBlock Grid.Row="7" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource FieldLabelStyle}" Text="关联来源" />
                                    <TextBlock Grid.Row="7" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" TextWrapping="Wrap" Text="{Binding SelectedEvidenceAssociationText}" />
                                </Grid>

                                <Border Margin="0,18,0,0"
                                        Height="180"
                                        Background="{DynamicResource MapSurfaceBrush}"
                                        BorderBrush="{DynamicResource PanelCardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource InnerCardCornerRadius}">
                                    <Grid>
                                        <Image Stretch="UniformToFill" Source="{Binding SelectedImageUri}">
                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasSelectedImage}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Text="当前未选择可预览的截图样本">
                                            <TextBlock.Style>
                                                <Style BasedOn="{StaticResource SectionHintStyle}" TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasSelectedImage}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>

                                <TextBlock Margin="0,18,0,6" Style="{StaticResource FieldLabelStyle}" Text="补充说明" />
                                <TextBlock Style="{StaticResource FieldValueStyle}"
                                           TextWrapping="Wrap"
                                           Text="{Binding SelectedEvidenceNoteText}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PanelCardStyle}">
                            <StackPanel>
                                <DockPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="人工复核结论" />
                                    <Border DockPanel.Dock="Right"
                                            Style="{StaticResource MiniBadgeStyle}"
                                            Background="{DynamicResource FilterBadgeBackgroundBrush}">
                                        <TextBlock Text="{Binding SelectedEvidenceManualReviewedAtText}" />
                                    </Border>
                                </DockPanel>

                                <TextBlock Margin="0,12,0,0"
                                           Style="{StaticResource SectionHintStyle}"
                                           TextWrapping="Wrap"
                                           Text="{Binding SaveStatusText}" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{DynamicResource ToneDangerBrush}"
                                           TextWrapping="Wrap"
                                           Text="{Binding SaveErrorText}" />

                                <TextBlock Margin="0,18,0,6" Style="{StaticResource FieldLabelStyle}" Text="复核结论" />
                                <ComboBox ItemsSource="{Binding ConclusionItems}"
                                          SelectedItem="{Binding SelectedConclusion}"
                                          DisplayMemberPath="Title" />

                                <TextBlock Margin="0,14,0,6" Style="{StaticResource FieldLabelStyle}" Text="复核人" />
                                <TextBox Text="{Binding Reviewer, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Margin="0,14,0,6" Style="{StaticResource FieldLabelStyle}" Text="复核备注" />
                                <TextBox Height="88"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         TextWrapping="Wrap"
                                         Text="{Binding ReviewRemark, UpdateSourceTrigger=PropertyChanged}" />

                                <CheckBox Margin="0,16,0,0"
                                          IsChecked="{Binding RequiresDispatch}"
                                          Content="后续需派单（结构预留）" />
                                <CheckBox Margin="0,8,0,0"
                                          IsChecked="{Binding RequiresRecheck}"
                                          Content="后续需复检" />

                                <WrapPanel Margin="0,18,0,0">
                                    <Button Style="{StaticResource ActionButtonStyle}"
                                            Command="{Binding SaveManualReviewCommand}"
                                            IsEnabled="{Binding CanSaveManualReview}"
                                            Content="{Binding SaveManualReviewButtonText}" />
                                    <Button Style="{StaticResource ActionButtonStyle}"
                                            Command="{Binding ResetReviewDraftCommand}"
                                            IsEnabled="{Binding HasSelectedDevice}"
                                            Content="重置表单" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <sharedPages:DeviceMediaReviewPanelView DataContext="{Binding MediaReview}" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
