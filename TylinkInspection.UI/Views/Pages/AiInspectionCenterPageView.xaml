<UserControl x:Class="TylinkInspection.UI.Views.Pages.AiInspectionCenterPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,4">
            <Border Style="{StaticResource PanelCardStyle}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{Binding PageTitle}" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource SectionHintStyle}"
                                   TextWrapping="Wrap"
                                   Text="{Binding PageSubtitle}" />
                    </StackPanel>
                    <Border DockPanel.Dock="Right"
                            Style="{StaticResource MiniBadgeStyle}"
                            Background="{DynamicResource FilterBadgeBackgroundBrush}">
                        <TextBlock Text="LOCAL WORKFLOW" />
                    </Border>
                </DockPanel>
            </Border>

            <ItemsControl ItemsSource="{Binding SummaryCards}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <primitives:UniformGrid Columns="4" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,16,16"
                                Padding="16"
                                Background="{DynamicResource MetricTileBackgroundBrush}"
                                BorderBrush="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource InnerCardCornerRadius}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding Label}" />
                                <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                    <TextBlock FontSize="{StaticResource FontSizeMetric}" FontWeight="Bold" Text="{Binding Value}" />
                                    <TextBlock Margin="6,10,0,0" Foreground="{DynamicResource SecondaryTextBrush}" Text="{Binding Unit}" />
                                </StackPanel>
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}"
                                           Text="{Binding DeltaText}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Style="{StaticResource PanelCardStyle}">
                <WrapPanel>
                    <TextBlock Style="{StaticResource FilterLabelStyle}" Text="时间范围" />
                    <ComboBox Width="140"
                              Style="{StaticResource FilterComboBoxStyle}"
                              ItemsSource="{Binding TimeRangeOptions}"
                              SelectedItem="{Binding SelectedTimeRange}" />

                    <TextBlock Style="{StaticResource FilterLabelStyle}" Text="状态" />
                    <ComboBox Width="140"
                              Style="{StaticResource FilterComboBoxStyle}"
                              ItemsSource="{Binding StatusOptions}"
                              SelectedItem="{Binding SelectedStatus}" />

                    <TextBlock Style="{StaticResource FilterLabelStyle}" Text="设备编码" />
                    <TextBox Width="180"
                             Style="{StaticResource FilterTextBoxStyle}"
                             Text="{Binding DeviceCode, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Style="{StaticResource FilterLabelStyle}" Text="关键字" />
                    <TextBox Width="220"
                             Style="{StaticResource FilterTextBoxStyle}"
                             Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}" />

                    <Button Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding SearchCommand}"
                            Content="执行筛选" />
                    <Button Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding ClearFilterCommand}"
                            Content="清空条件" />
                </WrapPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="360" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource PanelCardStyle}" Margin="0,0,18,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="巡检任务列表" />
                        <TextBlock Margin="0,8,0,18"
                                   Style="{StaticResource SectionHintStyle}"
                                   Text="任务列表仍由本地仓储驱动，但右侧和中部已经联动真实普通设备告警。" />

                        <ListBox ItemsSource="{Binding TaskItems}"
                                 SelectedItem="{Binding SelectedTask}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ListItemCardStyle}"
                                            BorderBrush="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}">
                                        <StackPanel>
                                            <DockPanel>
                                                <TextBlock FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           Text="{Binding Title}" />
                                                <Border DockPanel.Dock="Right"
                                                        Style="{StaticResource StatusBadgeBorderStyle}"
                                                        BorderBrush="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}">
                                                    <TextBlock Foreground="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}"
                                                               Text="{Binding Status}" />
                                                </Border>
                                            </DockPanel>
                                            <TextBlock Margin="0,10,0,0"
                                                       Style="{StaticResource FieldValueStyle}"
                                                       Text="{Binding DeviceCode}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       Text="{Binding RegionName}" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Style="{StaticResource SectionHintStyle}"
                                                       Text="{Binding SourceName}" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Style="{StaticResource SectionHintStyle}"
                                                       Text="{Binding ScheduledAt, StringFormat='计划执行 {0:MM-dd HH:mm}'}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource PanelCardStyle}" Margin="0,0,18,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="巡检联动区" />
                        <TextBlock Margin="0,8,0,12"
                                   Style="{StaticResource SectionHintStyle}"
                                   Text="{Binding RelatedAlarmStatusText}" />
                        <TextBlock Margin="0,0,0,18"
                                   Foreground="{DynamicResource ToneDangerBrush}"
                                   TextWrapping="Wrap"
                                   Text="{Binding RelatedAlarmErrorText}" />

                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="关联设备告警" />
                        <ItemsControl Margin="0,10,0,18" ItemsSource="{Binding RelatedDeviceAlarms}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ListItemCardStyle}"
                                            BorderBrush="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}">
                                        <StackPanel>
                                            <DockPanel>
                                                <TextBlock FontWeight="SemiBold" Text="{Binding AlarmTypeName}" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           Foreground="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}"
                                                           Text="{Binding SeverityOrStatusText}" />
                                            </DockPanel>
                                            <TextBlock Margin="0,8,0,0"
                                                       Style="{StaticResource FieldValueStyle}"
                                                       Text="{Binding DeviceCode}" />
                                            <TextBlock Margin="0,8,0,0"
                                                       TextWrapping="Wrap"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       Text="{Binding Content}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="最近执行记录" />
                        <ItemsControl Margin="0,10,0,0" ItemsSource="{Binding ExecutionRecords}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ListItemCardStyle}"
                                            BorderBrush="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}">
                                        <StackPanel>
                                            <DockPanel>
                                                <TextBlock FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           Text="{Binding Message}" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           Foreground="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}"
                                                           Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}" />
                                            </DockPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource PanelCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="任务详情面板" />
                        <TextBlock Margin="0,8,0,18"
                                   Style="{StaticResource SectionHintStyle}"
                                   Text="右侧保留任务状态流转、备注和手动重试。后续可以继续挂接更多真实巡检结果。" />

                        <Border Style="{StaticResource StatusBadgeBorderStyle}"
                                BorderBrush="{Binding SelectedTaskAccentResourceKey, Converter={StaticResource ResourceLookupConverter}}"
                                HorizontalAlignment="Left">
                            <TextBlock Foreground="{Binding SelectedTaskAccentResourceKey, Converter={StaticResource ResourceLookupConverter}}"
                                       Text="{Binding SelectedTaskStatusText}" />
                        </Border>

                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="设备编码" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedTaskDetail.DeviceCode, TargetNullValue=--}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,10,0,4" Style="{StaticResource FieldLabelStyle}" Text="区域" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedTaskDetail.RegionName, TargetNullValue=--}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,10,0,4" Style="{StaticResource FieldLabelStyle}" Text="策略" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedTaskStrategyText}" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,10,0,4" Style="{StaticResource FieldLabelStyle}" Text="最近备注" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedTaskLatestNoteText}" />
                        </Grid>

                        <TextBlock Margin="0,20,0,6" Style="{StaticResource FieldLabelStyle}" Text="执行窗口" />
                        <TextBlock Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedTaskWindowText}" />

                        <TextBlock Margin="0,14,0,6" Style="{StaticResource FieldLabelStyle}" Text="任务说明" />
                        <TextBlock Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedTaskDescriptionText}" />

                        <TextBlock Margin="0,20,0,6" Style="{StaticResource FieldLabelStyle}" Text="操作备注" />
                        <TextBox Height="96"
                                 Margin="0,0,0,18"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Style="{StaticResource FilterTextBoxStyle}"
                                 Text="{Binding ActionNote, UpdateSourceTrigger=PropertyChanged}" />

                        <WrapPanel>
                            <Button Style="{StaticResource ActionButtonStyle}"
                                    Command="{Binding UpdateStatusCommand}"
                                    CommandParameter="待执行"
                                    Content="转待执行" />
                            <Button Style="{StaticResource ActionButtonStyle}"
                                    Command="{Binding UpdateStatusCommand}"
                                    CommandParameter="执行中"
                                    Content="转执行中" />
                            <Button Style="{StaticResource ActionButtonStyle}"
                                    Command="{Binding UpdateStatusCommand}"
                                    CommandParameter="已完成"
                                    Content="标记完成" />
                            <Button Style="{StaticResource ActionButtonStyle}"
                                    Command="{Binding UpdateStatusCommand}"
                                    CommandParameter="异常中"
                                    Content="标记异常" />
                            <Button Style="{StaticResource ActionButtonStyle}"
                                    Command="{Binding RetryCommand}"
                                    Content="手动重试" />
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
