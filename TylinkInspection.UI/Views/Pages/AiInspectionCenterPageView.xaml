<UserControl x:Class="TylinkInspection.UI.Views.Pages.AiInspectionCenterPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,4">
            <Border Style="{StaticResource PanelCardStyle}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{Binding PageTitle}" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource SectionHintStyle}"
                                   TextWrapping="Wrap"
                                   Text="{Binding PageSubtitle}" />
                    </StackPanel>
                    <Border DockPanel.Dock="Right"
                            Style="{StaticResource MiniBadgeStyle}"
                            Background="{DynamicResource FilterBadgeBackgroundBrush}">
                        <TextBlock Text="TASK CONTROL" />
                    </Border>
                </DockPanel>
            </Border>

            <ItemsControl ItemsSource="{Binding SummaryCards}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <primitives:UniformGrid Columns="4" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,16,16"
                                Padding="16"
                                Background="{DynamicResource MetricTileBackgroundBrush}"
                                BorderBrush="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource InnerCardCornerRadius}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding Label}" />
                                <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                    <TextBlock FontSize="{StaticResource FontSizeMetric}" FontWeight="Bold" Text="{Binding Value}" />
                                    <TextBlock Margin="6,10,0,0" Foreground="{DynamicResource SecondaryTextBrush}" Text="{Binding Unit}" />
                                </StackPanel>
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}"
                                           Text="{Binding DeltaText}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Style="{StaticResource PanelCardStyle}">
                <WrapPanel>
                    <TextBlock Style="{StaticResource FilterLabelStyle}" Text="任务检索" />
                    <TextBox Width="220"
                             Style="{StaticResource FilterTextBoxStyle}"
                             Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Style="{StaticResource FilterLabelStyle}" Text="状态" />
                    <ComboBox Width="150"
                              Style="{StaticResource FilterComboBoxStyle}"
                              ItemsSource="{Binding StatusOptions}"
                              SelectedItem="{Binding SelectedStatus}" />

                    <Button Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding RefreshCommand}"
                            Content="刷新列表" />
                    <Button Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding ClearFilterCommand}"
                            Content="清空筛选" />
                </WrapPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="420" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource PanelCardStyle}" Margin="0,0,18,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="任务创建区" />
                        <TextBlock Margin="0,8,0,6"
                                   Style="{StaticResource FieldLabelStyle}"
                                   Text="当前巡检范围方案" />
                        <TextBlock Style="{StaticResource FieldValueStyle}" Text="{Binding CurrentSchemeName}" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource SectionHintStyle}"
                                   TextWrapping="Wrap"
                                   Text="{Binding CurrentSchemeSummary}" />

                        <TextBlock Margin="0,18,0,6" Style="{StaticResource FieldLabelStyle}" Text="任务名称" />
                        <TextBox Style="{StaticResource FilterTextBoxStyle}"
                                 Text="{Binding TaskName, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,18,0,6" Style="{StaticResource FieldLabelStyle}" Text="任务类型" />
                        <ComboBox Style="{StaticResource FilterComboBoxStyle}"
                                  ItemsSource="{Binding TaskTypeOptions}"
                                  DisplayMemberPath="Title"
                                  SelectedValuePath="Key"
                                  SelectedValue="{Binding SelectedCreateTaskType}" />

                        <TextBlock Margin="0,18,0,6" Style="{StaticResource FieldLabelStyle}" Text="任务范围" />
                        <ComboBox Style="{StaticResource FilterComboBoxStyle}"
                                  ItemsSource="{Binding ScopeModeOptions}"
                                  DisplayMemberPath="Title"
                                  SelectedValuePath="Key"
                                  SelectedValue="{Binding SelectedCreateScopeMode}" />

                        <TextBlock Margin="0,18,0,6" Style="{StaticResource FieldLabelStyle}" Text="创建人" />
                        <TextBox Style="{StaticResource FilterTextBoxStyle}"
                                 Text="{Binding OperatorName, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,18,0,12"
                                   Style="{StaticResource SectionHintStyle}"
                                   TextWrapping="Wrap"
                                   Text="本轮仅支持立即执行。创建后会自动拆分为点位子任务并进入本地队列，应用重启后会恢复未完成任务。" />

                        <Button Style="{StaticResource ActionButtonStyle}"
                                Command="{Binding CreateAndRunCommand}"
                                Content="创建并立即执行" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource PanelCardStyle}" Margin="0,0,18,0">
                    <StackPanel>
                        <DockPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="任务批次列表" />
                            <TextBlock DockPanel.Dock="Right"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource SectionHintStyle}"
                                       Text="{Binding TaskItems.Count, StringFormat='共 {0} 个批次'}" />
                        </DockPanel>
                        <TextBlock Margin="0,8,0,18"
                                   Style="{StaticResource SectionHintStyle}"
                                   Text="列表聚合展示批次名称、任务类型、范围、执行统计与当前状态。" />

                        <ListBox ItemsSource="{Binding TaskItems}"
                                 SelectedItem="{Binding SelectedTask}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ListItemCardStyle}"
                                            BorderBrush="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}">
                                        <StackPanel>
                                            <DockPanel>
                                                <TextBlock FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           Text="{Binding TaskName}" />
                                                <Border DockPanel.Dock="Right"
                                                        Style="{StaticResource StatusBadgeBorderStyle}"
                                                        BorderBrush="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}">
                                                    <TextBlock Foreground="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}"
                                                               Text="{Binding StatusText}" />
                                                </Border>
                                            </DockPanel>

                                            <Grid Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="72" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="72" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="类型" />
                                                <TextBlock Grid.Column="1" Style="{StaticResource FieldValueStyle}" Text="{Binding TaskTypeText}" />
                                                <TextBlock Grid.Column="2" Style="{StaticResource FieldLabelStyle}" Text="范围" />
                                                <TextBlock Grid.Column="3" Style="{StaticResource FieldValueStyle}" Text="{Binding ScopeModeText}" />
                                            </Grid>

                                            <Grid Margin="0,8,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="72" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="72" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="点位数" />
                                                <TextBlock Grid.Column="1" Style="{StaticResource FieldValueStyle}" Text="{Binding TotalCount}" />
                                                <TextBlock Grid.Column="2" Style="{StaticResource FieldLabelStyle}" Text="进度" />
                                                <TextBlock Grid.Column="3" Style="{StaticResource FieldValueStyle}" Text="{Binding ProgressText}" />
                                            </Grid>

                                            <TextBlock Margin="0,8,0,0"
                                                       Style="{StaticResource SectionHintStyle}"
                                                       Text="{Binding SucceededCount, StringFormat='成功 {0}'}" />
                                            <TextBlock Margin="0,2,0,0"
                                                       Style="{StaticResource SectionHintStyle}"
                                                       Text="{Binding FailedCount, StringFormat='失败 {0}'}" />
                                            <TextBlock Margin="0,2,0,0"
                                                       Style="{StaticResource SectionHintStyle}"
                                                       Text="{Binding AbnormalCount, StringFormat='异常 {0}'}" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Style="{StaticResource SectionHintStyle}"
                                                       Text="{Binding CreatedAt, StringFormat='创建时间 {0:yyyy-MM-dd HH:mm:ss}'}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource PanelCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="任务详情区" />
                        <TextBlock Margin="0,8,0,12"
                                   Style="{StaticResource SectionHintStyle}"
                                   Text="展示子任务列表、当前进度、失败摘要和最近执行记录。" />

                        <Border Style="{StaticResource StatusBadgeBorderStyle}"
                                BorderBrush="{Binding SelectedTaskAccentResourceKey, Converter={StaticResource ResourceLookupConverter}}"
                                HorizontalAlignment="Left">
                            <TextBlock Foreground="{Binding SelectedTaskAccentResourceKey, Converter={StaticResource ResourceLookupConverter}}"
                                       Text="{Binding SelectedTaskStatusText}" />
                        </Border>

                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="96" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="任务类型" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedTaskTypeText}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,0,0" Style="{StaticResource FieldLabelStyle}" Text="任务范围" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,8,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedTaskScopeText}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,0,0" Style="{StaticResource FieldLabelStyle}" Text="巡检方案" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,8,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedTaskSchemeText}" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,8,0,0" Style="{StaticResource FieldLabelStyle}" Text="创建时间" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,8,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedTaskCreatedText}" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,8,0,0" Style="{StaticResource FieldLabelStyle}" Text="启动/完成" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,8,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedTaskStartedText}" />

                            <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,8,0,0" Style="{StaticResource FieldLabelStyle}" Text="统计" />
                            <TextBlock Grid.Row="5" Grid.Column="1" Margin="0,8,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedTaskCountsText}" />
                        </Grid>

                        <TextBlock Margin="0,16,0,6" Style="{StaticResource FieldLabelStyle}" Text="当前进度" />
                        <TextBlock Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedTaskProgressText}" />

                        <TextBlock Margin="0,14,0,6" Style="{StaticResource FieldLabelStyle}" Text="失败摘要" />
                        <TextBlock Style="{StaticResource FieldValueStyle}" TextWrapping="Wrap" Text="{Binding SelectedTaskFailureSummary}" />

                        <TextBlock Margin="0,14,0,6" Style="{StaticResource FieldLabelStyle}" Text="最近结果摘要" />
                        <TextBlock Style="{StaticResource FieldValueStyle}" TextWrapping="Wrap" Text="{Binding SelectedTaskLatestSummary}" />

                        <WrapPanel Margin="0,18,0,12">
                            <Button Style="{StaticResource ActionButtonStyle}"
                                    Command="{Binding StartSelectedTaskCommand}"
                                    Content="启动任务" />
                            <Button Style="{StaticResource ActionButtonStyle}"
                                    Command="{Binding CancelSelectedTaskCommand}"
                                    Content="取消未完成" />
                        </WrapPanel>

                        <TextBlock Margin="0,6,0,8" Style="{StaticResource FieldLabelStyle}" Text="子任务列表" />
                        <ItemsControl ItemsSource="{Binding DetailItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ListItemCardStyle}"
                                            BorderBrush="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}">
                                        <StackPanel>
                                            <DockPanel>
                                                <TextBlock FontWeight="SemiBold" Text="{Binding DeviceName}" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           Foreground="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}"
                                                           Text="{Binding ExecutionStatusText}" />
                                            </DockPanel>
                                            <TextBlock Margin="0,8,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding DeviceCode}" />
                                            <TextBlock Margin="0,4,0,0" Style="{StaticResource SectionHintStyle}" Text="{Binding DirectoryPath}" />
                                            <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" Style="{StaticResource SectionHintStyle}" Text="{Binding LastResultSummaryText}" />
                                            <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Foreground="{DynamicResource ToneDangerBrush}" Text="{Binding LastErrorText}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Margin="0,18,0,8" Style="{StaticResource FieldLabelStyle}" Text="执行记录" />
                        <ItemsControl ItemsSource="{Binding ExecutionRecords}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ListItemCardStyle}"
                                            BorderBrush="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}">
                                        <DockPanel>
                                            <TextBlock TextWrapping="Wrap"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding Message}" />
                                            <TextBlock DockPanel.Dock="Right"
                                                       Foreground="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}"
                                                       Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}" />
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
