<UserControl x:Class="TylinkInspection.UI.Views.Pages.AiInspectionCenterPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Style="{StaticResource PanelCardStyle}">
                <DockPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{Binding PageTitle}" />
                    <TextBlock Margin="12,4,0,0"
                               DockPanel.Dock="Right"
                               Style="{StaticResource SectionHintStyle}"
                               Text="{Binding PageSubtitle}" />
                </DockPanel>
            </Border>

            <Border Style="{StaticResource PanelCardStyle}">
                <WrapPanel>
                    <TextBlock Style="{StaticResource FilterLabelStyle}" Text="检索" />
                    <TextBox Width="220" Style="{StaticResource FilterTextBoxStyle}" Text="{Binding Keyword}" />
                    <TextBlock Style="{StaticResource FilterLabelStyle}" Text="状态" />
                    <ComboBox Width="150"
                              Style="{StaticResource FilterComboBoxStyle}"
                              ItemsSource="{Binding StatusOptions}"
                              SelectedItem="{Binding SelectedStatus}" />
                    <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding RefreshCommand}" Content="刷新" />
                    <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding ClearFilterCommand}" Content="清空" />
                </WrapPanel>
            </Border>

            <Border Style="{StaticResource PanelCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource FieldValueStyle}" Text="{Binding TaskCenterFilterText}" TextWrapping="Wrap" />
                    <TextBlock Margin="0,6,0,0"
                               Style="{StaticResource SectionHintStyle}"
                               Text="{Binding TaskCenterContextText}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="440" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Margin="0,0,16,0" Style="{StaticResource PanelCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="任务创建" />
                        <TextBlock Margin="0,8,0,6" Style="{StaticResource FieldLabelStyle}" Text="{Binding CurrentSchemeName}" />
                        <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding CurrentSchemeSummary}" TextWrapping="Wrap" />

                        <TextBlock Margin="0,10,0,4" Style="{StaticResource FieldLabelStyle}" Text="任务名称" />
                        <TextBox Style="{StaticResource FilterTextBoxStyle}" Text="{Binding TaskName}" />
                        <TextBlock Margin="0,10,0,4" Style="{StaticResource FieldLabelStyle}" Text="任务类型" />
                        <ComboBox Style="{StaticResource FilterComboBoxStyle}"
                                  ItemsSource="{Binding TaskTypeOptions}"
                                  DisplayMemberPath="Title"
                                  SelectedValuePath="Key"
                                  SelectedValue="{Binding SelectedCreateTaskType}" />
                        <TextBlock Margin="0,10,0,4" Style="{StaticResource FieldLabelStyle}" Text="任务范围" />
                        <ComboBox Style="{StaticResource FilterComboBoxStyle}"
                                  ItemsSource="{Binding ScopeModeOptions}"
                                  DisplayMemberPath="Title"
                                  SelectedValuePath="Key"
                                  SelectedValue="{Binding SelectedCreateScopeMode}" />
                        <Button Margin="0,10,0,0"
                                Style="{StaticResource ActionButtonStyle}"
                                Command="{Binding CreateAndRunCommand}"
                                Content="创建并执行" />

                        <Separator Margin="0,14,0,12" />

                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="任务计划" />
                        <TextBlock Margin="0,8,0,4" Style="{StaticResource FieldLabelStyle}" Text="计划名称" />
                        <TextBox Style="{StaticResource FilterTextBoxStyle}" Text="{Binding PlanName}" />
                        <TextBlock Margin="0,8,0,4" Style="{StaticResource FieldLabelStyle}" Text="计划类型" />
                        <ComboBox Style="{StaticResource FilterComboBoxStyle}"
                                  ItemsSource="{Binding TaskTypeOptions}"
                                  DisplayMemberPath="Title"
                                  SelectedValuePath="Key"
                                  SelectedValue="{Binding SelectedPlanTaskType}" />
                        <TextBlock Margin="0,8,0,4" Style="{StaticResource FieldLabelStyle}" Text="计划范围" />
                        <ComboBox Style="{StaticResource FilterComboBoxStyle}"
                                  ItemsSource="{Binding ScopeModeOptions}"
                                  DisplayMemberPath="Title"
                                  SelectedValuePath="Key"
                                  SelectedValue="{Binding SelectedPlanScopeMode}" />
                        <WrapPanel Margin="0,8,0,0">
                            <TextBox Width="56" Style="{StaticResource FilterTextBoxStyle}" Text="{Binding PlanHourText}" />
                            <TextBlock Margin="6,8,6,0" Text=":" />
                            <TextBox Width="56" Style="{StaticResource FilterTextBoxStyle}" Text="{Binding PlanMinuteText}" />
                        </WrapPanel>
                        <Button Margin="0,10,0,0"
                                Style="{StaticResource ActionButtonStyle}"
                                Command="{Binding CreateDailyPlanCommand}"
                                Content="创建每日计划" />
                        <Button Margin="0,8,0,0"
                                Style="{StaticResource ActionButtonStyle}"
                                Command="{Binding ToggleSelectedPlanEnabledCommand}"
                                Content="启用/停用选中计划" />

                        <TextBlock Margin="0,10,0,4" Style="{StaticResource SectionHintStyle}" Text="{Binding SelectedPlanStatusText}" />
                        <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding SelectedPlanNextRunText}" />

                        <ListBox Margin="0,10,0,0"
                                 MaxHeight="260"
                                 ItemsSource="{Binding TaskPlans}"
                                 SelectedItem="{Binding SelectedPlan}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ListItemCardStyle}">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding PlanName}" />
                                            <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding ScheduleText}" />
                                            <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding EnabledText}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Margin="0,0,16,0" Style="{StaticResource PanelCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="任务批次列表" />
                        <ListBox Margin="0,10,0,0" ItemsSource="{Binding TaskItems}" SelectedItem="{Binding SelectedTask}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ListItemCardStyle}"
                                            BorderBrush="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding TaskName}" TextWrapping="Wrap" />
                                            <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding SourceText}" />
                                            <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding LatestResultSummary}" TextWrapping="Wrap" />
                                            <TextBlock Style="{StaticResource SectionHintStyle}"
                                                       Text="{Binding ResultSummary.PendingManualReviewCount, StringFormat='待复核 {0}'}" />
                                            <TextBlock Style="{StaticResource SectionHintStyle}"
                                                       Text="{Binding ResultSummary.PendingClosureCount, StringFormat='待闭环 {0}'}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource PanelCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="任务详情" />
                        <TextBlock Margin="0,8,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedTaskStatusText}" />
                        <TextBlock Margin="0,4,0,0" Style="{StaticResource SectionHintStyle}" Text="{Binding SelectedTaskSourceText}" />
                        <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding SelectedTaskPlanText}" TextWrapping="Wrap" />
                        <TextBlock Margin="0,4,0,0" Style="{StaticResource SectionHintStyle}" Text="{Binding SelectedTaskCountsText}" />
                        <TextBlock Margin="0,4,0,0" Style="{StaticResource SectionHintStyle}" Text="{Binding SelectedTaskPendingText}" />
                        <TextBlock Margin="0,4,0,0" Style="{StaticResource SectionHintStyle}" Text="{Binding SelectedTaskFailureDigestText}" TextWrapping="Wrap" />
                        <TextBlock Margin="0,4,0,0" Style="{StaticResource SectionHintStyle}" Text="{Binding SelectedTaskJumpEntryText}" TextWrapping="Wrap" />
                        <TextBlock Margin="0,8,0,0" Style="{StaticResource FieldLabelStyle}" Text="{Binding SelectedTaskResultHeadline}" />
                        <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding SelectedTaskBasicSummary}" TextWrapping="Wrap" />
                        <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding SelectedTaskPlaybackSummary}" TextWrapping="Wrap" />
                        <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding SelectedTaskScreenshotSummary}" TextWrapping="Wrap" />
                        <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding SelectedTaskRecheckSummary}" TextWrapping="Wrap" />
                        <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding SelectedTaskClosureSummary}" TextWrapping="Wrap" />

                        <WrapPanel Margin="0,10,0,0">
                            <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding StartSelectedTaskCommand}" Content="启动" />
                            <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding CancelSelectedTaskCommand}" Content="取消" />
                            <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding RerunFailedItemsCommand}" Content="重跑失败项" />
                            <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding RerunUnsuccessfulItemsCommand}" Content="重跑未成功项" />
                        </WrapPanel>

                        <WrapPanel Margin="0,8,0,0">
                            <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding NavigateToPointGovernanceCommand}" Content="点位治理" />
                            <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding NavigateToMapInspectionCommand}" Content="地图巡检台" />
                            <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding NavigateToReviewCenterCommand}" Content="复核中心" />
                            <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding NavigateToFaultClosureCommand}" Content="故障闭环" />
                        </WrapPanel>

                        <TextBlock Margin="0,10,0,4" Style="{StaticResource FieldLabelStyle}" Text="子任务" />
                        <ListBox MaxHeight="220"
                                 ItemsSource="{Binding DetailItems}"
                                 SelectedItem="{Binding SelectedTaskItem}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ListItemCardStyle}">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding DeviceName}" />
                                            <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding DeviceCode}" />
                                            <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding LastResultSummaryText}" TextWrapping="Wrap" />
                                            <TextBlock Foreground="{DynamicResource ToneDangerBrush}" Text="{Binding LastErrorText}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Button Margin="0,8,0,0"
                                Style="{StaticResource ActionButtonStyle}"
                                Command="{Binding RetrySelectedItemCommand}"
                                Content="重试选中子任务" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.15*" />
                    <ColumnDefinition Width="0.85*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Margin="0,0,16,0" Style="{StaticResource PanelCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="计划执行历史" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource SectionHintStyle}"
                                   Text="上方选择任务计划后，这里持续查看该计划的实例化批次和最近执行结果。" />

                        <ListBox Margin="0,14,0,0"
                                 MaxHeight="240"
                                 ItemsSource="{Binding PlanHistoryItems}"
                                 SelectedItem="{Binding SelectedPlanHistoryEntry}"
                                 Background="Transparent"
                                 BorderThickness="0">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,10" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ListItemCardStyle}">
                                        <StackPanel>
                                            <DockPanel>
                                                <TextBlock FontWeight="SemiBold" Text="{Binding PlanName}" />
                                                <Border DockPanel.Dock="Right"
                                                        Style="{StaticResource MiniBadgeStyle}"
                                                        Background="{DynamicResource FilterBadgeBackgroundBrush}">
                                                    <TextBlock Text="{Binding EnabledText}" />
                                                </Border>
                                            </DockPanel>
                                            <TextBlock Margin="0,6,0,0"
                                                       Style="{StaticResource SectionHintStyle}"
                                                       Text="{Binding TaskTypeText}" />
                                            <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding ScheduleText}" />
                                            <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding LastRunAtText, StringFormat='最近执行: {0}'}" />
                                            <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding LatestTaskText, StringFormat='最近批次: {0}'}" TextWrapping="Wrap" />
                                            <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding CountersText}" />
                                            <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding PendingText}" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Style="{StaticResource SectionHintStyle}"
                                                       Text="{Binding LatestResultSummary}"
                                                       TextWrapping="Wrap" />
                                            <WrapPanel Margin="0,10,0,0">
                                                <Button Style="{StaticResource ActionButtonStyle}"
                                                        Command="{Binding DataContext.OpenHistoryLatestBatchCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="最近批次详情" />
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Separator Margin="0,14,0,12" />

                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="选中计划历史批次" />
                        <TextBlock Margin="0,8,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedPlanHistoryName}" />
                        <TextBlock Margin="0,4,0,0" Style="{StaticResource SectionHintStyle}" Text="{Binding SelectedPlanHistoryTypeText}" />
                        <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding SelectedPlanHistoryScheduleText}" />
                        <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding SelectedPlanHistoryLastRunText, StringFormat='最近执行: {0}'}" />
                        <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding SelectedPlanHistoryLatestTaskText, StringFormat='最近批次: {0}'}" TextWrapping="Wrap" />
                        <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding SelectedPlanHistoryCountersText}" />
                        <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding SelectedPlanHistoryPendingText}" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource SectionHintStyle}"
                                   Text="{Binding SelectedPlanHistoryResultText}"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,4,0,0" Style="{StaticResource SectionHintStyle}" Text="{Binding SelectedPlanHistoryEnabledText}" />

                        <ListBox Margin="0,14,0,0"
                                 MaxHeight="260"
                                 ItemsSource="{Binding SelectedPlanExecutionBatches}"
                                 Background="Transparent"
                                 BorderThickness="0">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,10" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ListItemCardStyle}"
                                            BorderBrush="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}">
                                        <StackPanel>
                                            <DockPanel>
                                                <TextBlock FontWeight="SemiBold" Text="{Binding TaskName}" TextWrapping="Wrap" />
                                                <Border DockPanel.Dock="Right"
                                                        Style="{StaticResource MiniBadgeStyle}"
                                                        Background="{DynamicResource FilterBadgeBackgroundBrush}">
                                                    <TextBlock Text="{Binding StatusText}" />
                                                </Border>
                                            </DockPanel>
                                            <TextBlock Margin="0,6,0,0"
                                                       Style="{StaticResource SectionHintStyle}"
                                                       Text="{Binding CreatedAt, StringFormat='实例化时间: {0:yyyy-MM-dd HH:mm:ss}'}" />
                                            <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding ResultSummary.SuccessCount, StringFormat='成功: {0}'}" />
                                            <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding ResultSummary.FailedCount, StringFormat='失败: {0}'}" />
                                            <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding ResultSummary.AbnormalCount, StringFormat='异常: {0}'}" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Style="{StaticResource SectionHintStyle}"
                                                       Text="{Binding LatestResultSummary}"
                                                       TextWrapping="Wrap" />
                                            <WrapPanel Margin="0,10,0,0">
                                                <Button Style="{StaticResource ActionButtonStyle}"
                                                        Command="{Binding DataContext.SelectTaskBatchCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="批次详情" />
                                                <Button Style="{StaticResource ActionButtonStyle}"
                                                        Command="{Binding DataContext.NavigateHistoryBatchToMapCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="地图" />
                                                <Button Style="{StaticResource ActionButtonStyle}"
                                                        Command="{Binding DataContext.NavigateHistoryBatchToPointGovernanceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="治理" />
                                                <Button Style="{StaticResource ActionButtonStyle}"
                                                        Command="{Binding DataContext.NavigateHistoryBatchToReviewCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="复核" />
                                                <Button Style="{StaticResource ActionButtonStyle}"
                                                        Command="{Binding DataContext.NavigateHistoryBatchToFaultClosureCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="闭环" />
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource PanelCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="计划级失败看板" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource SectionHintStyle}"
                                   Text="用于快速判断最近失败最多的计划、任务类型和反复失败点位，不做复杂图形展示。" />

                        <Border Margin="0,14,0,0"
                                Padding="12"
                                Background="{DynamicResource MetricTileBackgroundBrush}"
                                BorderBrush="{DynamicResource PanelCardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource InnerCardCornerRadius}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="失败焦点" />
                                <TextBlock Margin="0,8,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding FailureBoardMostFailedPlanText}" TextWrapping="Wrap" />
                                <TextBlock Margin="0,6,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding FailureBoardMostFailedTaskTypeText}" TextWrapping="Wrap" />
                                <TextBlock Margin="0,6,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding FailureBoardMostRepeatedPointText}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <TextBlock Margin="0,16,0,6" Style="{StaticResource FieldLabelStyle}" Text="最近失败计划" />
                        <ItemsControl ItemsSource="{Binding FailurePlanItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Style="{StaticResource ListItemCardStyle}">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding PlanName}" />
                                            <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding TaskTypeText}" />
                                            <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding HeadlineText}" TextWrapping="Wrap" />
                                            <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding LastFailedAtText, StringFormat='最近失败: {0}'}" />
                                            <WrapPanel Margin="0,10,0,0">
                                                <Button Style="{StaticResource ActionButtonStyle}"
                                                        Command="{Binding DataContext.OpenFailedPlanCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="计划详情" />
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Margin="0,12,0,6" Style="{StaticResource FieldLabelStyle}" Text="最近失败批次" />
                        <ItemsControl ItemsSource="{Binding FailureBatchItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Style="{StaticResource ListItemCardStyle}">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding TaskName}" TextWrapping="Wrap" />
                                            <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding SourceText}" />
                                            <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding OccurredAtText, StringFormat='失败时间: {0}'}" />
                                            <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding FailureSummary}" TextWrapping="Wrap" />
                                            <WrapPanel Margin="0,10,0,0">
                                                <Button Style="{StaticResource ActionButtonStyle}"
                                                        Command="{Binding DataContext.OpenFailedBatchCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="批次详情" />
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Margin="0,12,0,6" Style="{StaticResource FieldLabelStyle}" Text="最近失败点位" />
                        <ItemsControl ItemsSource="{Binding FailurePointItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Style="{StaticResource ListItemCardStyle}">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding DeviceName}" />
                                            <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding DeviceCode}" />
                                            <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding TaskName}" TextWrapping="Wrap" />
                                            <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding FailureReason}" TextWrapping="Wrap" />
                                            <WrapPanel Margin="0,10,0,0">
                                                <Button Style="{StaticResource ActionButtonStyle}"
                                                        Command="{Binding DataContext.OpenFailedPointCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="智能跳转" />
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Margin="0,12,0,6" Style="{StaticResource FieldLabelStyle}" Text="失败原因分类" />
                        <ItemsControl ItemsSource="{Binding FailureReasonItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Style="{StaticResource ListItemCardStyle}">
                                        <StackPanel>
                                            <DockPanel>
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Text="{Binding CategoryName}" />
                                                <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding AffectedPointCount, StringFormat='影响点位: {0}'}" />
                                            </StackPanel>
                                            <TextBlock DockPanel.Dock="Right"
                                                       Style="{StaticResource FieldValueStyle}"
                                                       Text="{Binding FailedItemCount, StringFormat='失败 {0}'}" />
                                        </DockPanel>
                                        <WrapPanel Margin="0,10,0,0">
                                            <Button Style="{StaticResource ActionButtonStyle}"
                                                    Command="{Binding DataContext.ApplyFailureReasonFilterCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Content="筛选明细" />
                                        </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Margin="0,12,0,6" Style="{StaticResource FieldLabelStyle}" Text="失败任务类型" />
                        <ItemsControl ItemsSource="{Binding TaskTypeFailureItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Style="{StaticResource ListItemCardStyle}">
                                        <StackPanel>
                                            <DockPanel>
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Text="{Binding TaskTypeText}" />
                                                <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding FailedBatchCount, StringFormat='失败批次: {0}'}" />
                                            </StackPanel>
                                            <TextBlock DockPanel.Dock="Right"
                                                       Style="{StaticResource FieldValueStyle}"
                                                       Text="{Binding FailedItemCount, StringFormat='失败 {0}'}" />
                                        </DockPanel>
                                        <WrapPanel Margin="0,10,0,0">
                                            <Button Style="{StaticResource ActionButtonStyle}"
                                                    Command="{Binding DataContext.ApplyTaskTypeFilterCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Content="筛选任务" />
                                        </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Margin="0,12,0,6" Style="{StaticResource FieldLabelStyle}" Text="连续失败点位" />
                        <ItemsControl ItemsSource="{Binding RepeatedFailurePointItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Style="{StaticResource ListItemCardStyle}">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding DeviceName}" />
                                            <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding DeviceCode}" />
                                            <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding HeadlineText}" TextWrapping="Wrap" />
                                            <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding LatestFailureReason}" TextWrapping="Wrap" />
                                            <WrapPanel Margin="0,10,0,0">
                                                <Button Style="{StaticResource ActionButtonStyle}"
                                                        Command="{Binding DataContext.OpenRepeatedFailurePointCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="进入处理" />
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
