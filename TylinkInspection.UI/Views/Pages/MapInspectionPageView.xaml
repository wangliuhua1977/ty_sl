<UserControl x:Class="TylinkInspection.UI.Views.Pages.MapInspectionPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PanelCardStyle}" Margin="0,0,0,18">
            <StackPanel>
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{Binding PageTitle}" />
                        <TextBlock Margin="0,8,0,0" Style="{StaticResource SectionHintStyle}" Text="{Binding PageSubtitle}" />
                    </StackPanel>
                    <Border DockPanel.Dock="Right" Style="{StaticResource MiniBadgeStyle}" Background="{DynamicResource FilterBadgeBackgroundBrush}">
                        <TextBlock Text="{Binding LastUpdatedText}" />
                    </Border>
                </DockPanel>
                <TextBlock Margin="0,14,0,0" Style="{StaticResource SectionHintStyle}" Text="{Binding MapCaption}" />
                <ItemsControl Margin="0,18,0,0" ItemsSource="{Binding OverviewMetrics}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <primitives:UniformGrid Columns="5" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,12,0"
                                    Padding="14"
                                    Background="{DynamicResource MetricTileBackgroundBrush}"
                                    BorderBrush="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource InnerCardCornerRadius}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding Label}" />
                                    <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                        <TextBlock FontSize="{StaticResource FontSizeMetric}" FontWeight="Bold" Text="{Binding Value}" />
                                        <TextBlock Margin="6,10,0,0" Foreground="{DynamicResource SecondaryTextBrush}" Text="{Binding Unit}" />
                                    </StackPanel>
                                    <TextBlock Margin="0,8,0,0" Foreground="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}" Text="{Binding DeltaText}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" Margin="0,0,18,0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource PanelCardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="区域方案切换" />
                            <ItemsControl Margin="0,16,0,0" ItemsSource="{Binding SchemeItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Margin="0,0,0,10" Command="{Binding DataContext.SelectSchemeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource SelectionButtonStyle}">
                                                    <Setter Property="Margin" Value="0,0,0,10" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Tag" Value="Selected" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <StackPanel>
                                                <TextBlock FontSize="14" FontWeight="SemiBold" Text="{Binding Title}" />
                                                <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource SecondaryTextBrush}" Text="{Binding Subtitle}" />
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelCardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="巡检任务" />
                            <ItemsControl Margin="0,16,0,0" ItemsSource="{Binding TaskTypeItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Margin="0,0,0,10" Command="{Binding DataContext.SelectTaskTypeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource SelectionButtonStyle}">
                                                    <Setter Property="Margin" Value="0,0,0,10" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Tag" Value="Selected" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock FontSize="15" FontWeight="SemiBold" Text="{Binding Title}" />
                                                    <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource SecondaryTextBrush}" Text="{Binding Subtitle}" />
                                                </StackPanel>
                                                <Border Grid.Column="1" Style="{StaticResource MiniBadgeStyle}" Background="{DynamicResource TaskCountBadgeBackgroundBrush}" Margin="12,0,0,0">
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding Badge}" />
                                                </Border>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelCardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="异常警情列表" />
                            <ItemsControl Margin="0,16,0,0" ItemsSource="{Binding AlertItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12"
                                                Padding="14"
                                                Background="{DynamicResource AlertItemBackgroundBrush}"
                                                BorderBrush="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}"
                                                BorderThickness="1"
                                                CornerRadius="{StaticResource InnerCardCornerRadius}">
                                            <StackPanel>
                                                <DockPanel>
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding SiteName}" />
                                                    <TextBlock DockPanel.Dock="Right" Foreground="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}" Text="{Binding TimeText}" />
                                                </DockPanel>
                                                <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Text="{Binding Message}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Column="1" Style="{StaticResource PanelCardStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="22,18,22,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="地图主舞台" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource SectionHintStyle}" Text="当前为占位地图底板，后续可替换为真实高德地图或业务底图。" />
                        </StackPanel>
                        <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                            <Border Style="{StaticResource MiniBadgeStyle}" Background="{DynamicResource MapLegendBackgroundBrush}" BorderBrush="{DynamicResource ToneSuccessBrush}"><TextBlock Text="正常点位" /></Border>
                            <Border Style="{StaticResource MiniBadgeStyle}" Background="{DynamicResource MapLegendBackgroundBrush}" BorderBrush="{DynamicResource ToneWarningBrush}"><TextBlock Text="异常点位" /></Border>
                            <Border Style="{StaticResource MiniBadgeStyle}" Background="{DynamicResource MapLegendBackgroundBrush}" BorderBrush="{DynamicResource ToneInfoBrush}"><TextBlock Text="待复核点位" /></Border>
                            <Border Style="{StaticResource MiniBadgeStyle}" Background="{DynamicResource MapLegendBackgroundBrush}" BorderBrush="{DynamicResource ToneFocusBrush}"><TextBlock Text="重点关注点位" /></Border>
                        </WrapPanel>
                    </Grid>

                    <Grid Grid.Row="1" Margin="22,20,22,12" ClipToBounds="True">
                        <Border Background="{DynamicResource MapSurfaceBrush}" BorderBrush="{DynamicResource MapBorderBrush}" BorderThickness="1" CornerRadius="{StaticResource ShellCornerRadius}" />
                        <Border Background="{DynamicResource MapGridBrush}" CornerRadius="{StaticResource ShellCornerRadius}" Opacity="0.65" />
                        <Canvas Margin="32">
                            <Path Stroke="{DynamicResource MapPathPrimaryBrush}" StrokeThickness="2" Data="M80,360 C170,270 270,260 360,180 S590,80 740,140" Opacity="0.8" />
                            <Path Stroke="{DynamicResource MapPathSecondaryBrush}" StrokeThickness="1.8" Data="M60,100 C120,160 250,210 380,230 S610,285 760,365" Opacity="0.85" />
                            <Path Fill="{DynamicResource MapRegionFillBrush}" Stroke="{DynamicResource MapRegionBorderBrush}" StrokeThickness="1.5" Data="M110,90 L255,60 L420,130 L565,115 L702,212 L632,360 L430,404 L216,338 L92,246 Z" Opacity="0.65" />
                            <Path Fill="{DynamicResource MapInnerRegionFillBrush}" Stroke="{DynamicResource MapInnerRegionBorderBrush}" StrokeThickness="1.2" Data="M248,142 L354,112 L480,176 L536,282 L410,332 L292,286 L224,226 Z" Opacity="0.72" />
                            <ItemsControl ItemsSource="{Binding MapMarkers}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><Canvas /></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}" />
                                        <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <Grid Width="18" Height="18">
                                                <Ellipse Fill="{Binding GlowBrushKey, Converter={StaticResource ResourceLookupConverter}}" />
                                                <Ellipse Width="10" Height="10" Fill="{Binding AccentBrushKey, Converter={StaticResource ResourceLookupConverter}}" Stroke="White" StrokeThickness="1.2" />
                                            </Grid>
                                            <Border Margin="-10,8,0,0"
                                                    Padding="10,6"
                                                    Background="{DynamicResource MapOverlayLabelBackgroundBrush}"
                                                    BorderBrush="{Binding AccentBrushKey, Converter={StaticResource ResourceLookupConverter}}"
                                                    BorderThickness="1"
                                                    CornerRadius="{StaticResource BadgeCornerRadius}">
                                                <StackPanel>
                                                    <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding Name}" />
                                                    <TextBlock Margin="0,2,0,0" FontSize="10" Foreground="{Binding AccentBrushKey, Converter={StaticResource ResourceLookupConverter}}" Text="{Binding StateLabel}" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Canvas>
                    </Grid>

                    <DockPanel Grid.Row="2" Margin="22,0,22,18">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Style="{StaticResource SectionHintStyle}" Text="说明" />
                            <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource SecondaryTextBrush}" Text="地图区域、点位、图层与统计条均由 ViewModel 假数据驱动，可直接替换为真实数据源。" />
                        </StackPanel>
                        <Border DockPanel.Dock="Right" Style="{StaticResource MiniBadgeStyle}" Background="{DynamicResource MapFooterBadgeBackgroundBrush}">
                            <TextBlock Text="地图接入状态: Mock Placeholder" />
                        </Border>
                    </DockPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Column="2" Margin="18,0,0,0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource PanelCardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="当前任务" />
                            <TextBlock Margin="0,12,0,0" FontSize="16" FontWeight="SemiBold" Text="{Binding CurrentTask.Title}" />
                            <TextBlock Margin="0,4,0,0" Style="{StaticResource SectionHintStyle}" Text="{Binding CurrentTask.RegionName}" />
                            <TextBlock Margin="0,2,0,14" Style="{StaticResource SectionHintStyle}" Text="{Binding CurrentTask.TimeWindow}" />
                            <ProgressBar Height="10" Maximum="1" Minimum="0" Value="{Binding CurrentTask.CompletionRate}" />
                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel><TextBlock Style="{StaticResource SectionHintStyle}" Text="完成数" /><TextBlock Margin="0,6,0,0" FontSize="24" FontWeight="Bold" Text="{Binding CurrentTask.CompletedCount}" /></StackPanel>
                                <StackPanel Grid.Column="1"><TextBlock Style="{StaticResource SectionHintStyle}" Text="异常数" /><TextBlock Margin="0,6,0,0" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource ToneWarningBrush}" Text="{Binding CurrentTask.AbnormalCount}" /></StackPanel>
                                <StackPanel Grid.Column="2"><TextBlock Style="{StaticResource SectionHintStyle}" Text="待复核" /><TextBlock Margin="0,6,0,0" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TonePrimaryBrush}" Text="{Binding CurrentTask.PendingReviewCount}" /></StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelCardStyle}">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="AI巡检助手" />
                                <Border DockPanel.Dock="Right" Style="{StaticResource MiniBadgeStyle}" Background="{DynamicResource AssistantChipBackgroundBrush}" BorderBrush="{DynamicResource TonePrimaryBrush}">
                                    <TextBlock Text="AI ENGINE" />
                                </Border>
                            </DockPanel>
                            <TextBlock Margin="0,18,0,0" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" Text="{Binding AssistantStatus.Headline}" />
                            <TextBlock Margin="0,10,0,0" TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Text="{Binding AssistantStatus.Detail}" />
                            <TextBlock Margin="0,12,0,0" Foreground="{DynamicResource ToneSuccessBrush}" Text="{Binding AssistantStatus.LastAction}" />
                            <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource TonePrimaryBrush}" Text="{Binding AssistantStatus.ConfidenceText}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelCardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="任务进展" />
                            <ItemsControl Margin="0,18,0,0" ItemsSource="{Binding ProgressItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12"
                                                Padding="14"
                                                Background="{DynamicResource TaskProgressBackgroundBrush}"
                                                BorderBrush="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}"
                                                BorderThickness="1"
                                                CornerRadius="{StaticResource InnerCardCornerRadius}">
                                            <DockPanel>
                                                <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" Text="{Binding Label}" />
                                                <TextBlock DockPanel.Dock="Right" FontSize="26" FontWeight="Bold" Foreground="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}" Text="{Binding Value}" />
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelCardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="待办事项" />
                            <ItemsControl Margin="0,18,0,0" ItemsSource="{Binding TodoItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12"
                                                Padding="14"
                                                Background="{DynamicResource TodoCardBackgroundBrush}"
                                                BorderBrush="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}"
                                                BorderThickness="1"
                                                CornerRadius="{StaticResource InnerCardCornerRadius}">
                                            <StackPanel>
                                                <DockPanel>
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                                                    <TextBlock DockPanel.Dock="Right" Foreground="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}" Text="{Binding DueText}" />
                                                </DockPanel>
                                                <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Text="{Binding Description}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelCardStyle}">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="雷达态势" />
                                <TextBlock DockPanel.Dock="Right" Foreground="{DynamicResource SecondaryTextBrush}" Text="实时占位图" />
                            </DockPanel>
                            <Grid Margin="0,18,0,0" HorizontalAlignment="Center">
                                <Canvas Width="220" Height="220">
                                    <Ellipse Width="220" Height="220" Stroke="{DynamicResource RadarPrimaryStrokeBrush}" StrokeThickness="1.2" />
                                    <Ellipse Width="160" Height="160" Canvas.Left="30" Canvas.Top="30" Stroke="{DynamicResource RadarMidStrokeBrush}" StrokeThickness="1.2" />
                                    <Ellipse Width="100" Height="100" Canvas.Left="60" Canvas.Top="60" Stroke="{DynamicResource RadarInnerStrokeBrush}" StrokeThickness="1.2" />
                                    <Line X1="110" Y1="0" X2="110" Y2="220" Stroke="{DynamicResource RadarSecondaryStrokeBrush}" StrokeThickness="1" />
                                    <Line X1="0" Y1="110" X2="220" Y2="110" Stroke="{DynamicResource RadarSecondaryStrokeBrush}" StrokeThickness="1" />
                                    <Path Stroke="{DynamicResource RadarSweepBrush}" StrokeThickness="2.2" Data="M110,110 L196,42" Opacity="0.9" />
                                    <ItemsControl ItemsSource="{Binding RadarSignals}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><Canvas /></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Left" Value="{Binding X}" />
                                                <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Ellipse Width="{Binding Size}" Height="{Binding Size}" Fill="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}" Opacity="{Binding Opacity}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Canvas>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
