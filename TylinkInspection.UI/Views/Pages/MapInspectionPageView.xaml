<UserControl x:Class="TylinkInspection.UI.Views.Pages.MapInspectionPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             xmlns:sharedPages="clr-namespace:TylinkInspection.UI.Views.Pages.Shared"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             Loaded="OnLoaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PanelCardStyle}" Margin="0,0,0,18">
            <StackPanel>
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{Binding PageTitle}" />
                        <TextBlock Margin="0,8,0,0" Style="{StaticResource SectionHintStyle}" Text="{Binding PageSubtitle}" />
                    </StackPanel>
                    <Border DockPanel.Dock="Right" Style="{StaticResource MiniBadgeStyle}" Background="{DynamicResource FilterBadgeBackgroundBrush}">
                        <TextBlock Text="{Binding LastUpdatedText}" />
                    </Border>
                </DockPanel>

                <TextBlock Margin="0,14,0,0" Style="{StaticResource SectionHintStyle}" Text="{Binding MapCaption}" />

                <ItemsControl Margin="0,18,0,0" ItemsSource="{Binding OverviewMetrics}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <primitives:UniformGrid Columns="5" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,12,0"
                                    Padding="14"
                                    Background="{DynamicResource MetricTileBackgroundBrush}"
                                    BorderBrush="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource InnerCardCornerRadius}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionHintStyle}" Text="{Binding Label}" />
                                    <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                        <TextBlock FontSize="{StaticResource FontSizeMetric}" FontWeight="Bold" Text="{Binding Value}" />
                                        <TextBlock Margin="6,10,0,0" Foreground="{DynamicResource SecondaryTextBrush}" Text="{Binding Unit}" />
                                    </StackPanel>
                                    <TextBlock Margin="0,8,0,0" Foreground="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}" Text="{Binding DeltaText}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" Margin="0,0,18,0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource PanelCardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="巡检范围方案" />
                            <ItemsControl Margin="0,16,0,0" ItemsSource="{Binding SchemeItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Margin="0,0,0,10"
                                                Command="{Binding DataContext.SelectSchemeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource SelectionButtonStyle}">
                                                    <Setter Property="Margin" Value="0,0,0,10" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Tag" Value="Selected" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <StackPanel>
                                                <TextBlock FontSize="14" FontWeight="SemiBold" Text="{Binding Title}" />
                                                <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource SecondaryTextBrush}" Text="{Binding Subtitle}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelCardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="巡检任务视角" />
                            <ItemsControl Margin="0,16,0,0" ItemsSource="{Binding TaskTypeItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Margin="0,0,0,10"
                                                Command="{Binding DataContext.SelectTaskTypeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource SelectionButtonStyle}">
                                                    <Setter Property="Margin" Value="0,0,0,10" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Tag" Value="Selected" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock FontSize="15" FontWeight="SemiBold" Text="{Binding Title}" />
                                                    <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource SecondaryTextBrush}" Text="{Binding Subtitle}" TextWrapping="Wrap" />
                                                </StackPanel>
                                                <Border Grid.Column="1" Style="{StaticResource MiniBadgeStyle}" Background="{DynamicResource TaskCountBadgeBackgroundBrush}" Margin="12,0,0,0">
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding Badge}" />
                                                </Border>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelCardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="异常摘要" />
                            <ItemsControl Margin="0,16,0,0" ItemsSource="{Binding AlertItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12"
                                                Padding="14"
                                                Background="{DynamicResource AlertItemBackgroundBrush}"
                                                BorderBrush="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}"
                                                BorderThickness="1"
                                                CornerRadius="{StaticResource InnerCardCornerRadius}">
                                            <StackPanel>
                                                <DockPanel>
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding SiteName}" />
                                                    <TextBlock DockPanel.Dock="Right" Foreground="{Binding AccentResourceKey, Converter={StaticResource ResourceLookupConverter}}" Text="{Binding TimeText}" />
                                                </DockPanel>
                                                <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Text="{Binding Message}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Column="1" Style="{StaticResource PanelCardStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="22,18,22,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="高德地图承载" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource SectionHintStyle}" Text="仅承载当前巡检范围方案内点位，地图坐标统一按 GCJ-02 展示。" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="{DynamicResource ToneDangerBrush}"
                                       Text="{Binding MapErrorText}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                            <Border Style="{StaticResource MiniBadgeStyle}" Background="{DynamicResource MapLegendBackgroundBrush}" BorderBrush="{DynamicResource ToneSuccessBrush}"><TextBlock Text="在线" /></Border>
                            <Border Style="{StaticResource MiniBadgeStyle}" Background="{DynamicResource MapLegendBackgroundBrush}" BorderBrush="{DynamicResource ToneWarningBrush}"><TextBlock Text="离线" /></Border>
                            <Border Style="{StaticResource MiniBadgeStyle}" Background="{DynamicResource MapLegendBackgroundBrush}" BorderBrush="{DynamicResource TonePrimaryBrush}"><TextBlock Text="A-E 等级" /></Border>
                            <Border Style="{StaticResource MiniBadgeStyle}" Background="{DynamicResource MapLegendBackgroundBrush}" BorderBrush="{DynamicResource ToneDangerBrush}"><TextBlock Text="需复检" /></Border>
                            <Border Style="{StaticResource MiniBadgeStyle}" Background="{DynamicResource MapLegendBackgroundBrush}" BorderBrush="{DynamicResource ToneFocusBrush}"><TextBlock Text="重点关注" /></Border>
                            <Border Style="{StaticResource MiniBadgeStyle}" Background="{DynamicResource MapLegendBackgroundBrush}" BorderBrush="{DynamicResource ToneInfoBrush}"><TextBlock Text="待补录坐标" /></Border>
                        </WrapPanel>
                    </Grid>

                    <Border Grid.Row="1"
                            Margin="22,20,22,18"
                            Background="{DynamicResource MapSurfaceBrush}"
                            BorderBrush="{DynamicResource MapBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource ShellCornerRadius}">
                        <wv2:WebView2 x:Name="MapWebView"
                                      DefaultBackgroundColor="Transparent" />
                    </Border>
                </Grid>
            </Border>

            <ScrollViewer Grid.Column="2" Margin="18,0,0,0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource PanelCardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="当前任务" />
                            <TextBlock Margin="0,12,0,0" FontSize="16" FontWeight="SemiBold" Text="{Binding CurrentTask.Title}" />
                            <TextBlock Margin="0,4,0,0" Style="{StaticResource SectionHintStyle}" Text="{Binding CurrentTask.RegionName}" />
                            <TextBlock Margin="0,2,0,14" Style="{StaticResource SectionHintStyle}" Text="{Binding CurrentTask.TimeWindow}" />
                            <ProgressBar Height="10" Maximum="1" Minimum="0" Value="{Binding CurrentTask.CompletionRate}" />
                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel><TextBlock Style="{StaticResource SectionHintStyle}" Text="完成数" /><TextBlock Margin="0,6,0,0" FontSize="24" FontWeight="Bold" Text="{Binding CurrentTask.CompletedCount}" /></StackPanel>
                                <StackPanel Grid.Column="1"><TextBlock Style="{StaticResource SectionHintStyle}" Text="异常数" /><TextBlock Margin="0,6,0,0" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource ToneWarningBrush}" Text="{Binding CurrentTask.AbnormalCount}" /></StackPanel>
                                <StackPanel Grid.Column="2"><TextBlock Style="{StaticResource SectionHintStyle}" Text="待复核" /><TextBlock Margin="0,6,0,0" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TonePrimaryBrush}" Text="{Binding CurrentTask.PendingReviewCount}" /></StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelCardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="当前点位" />
                            <TextBlock Margin="0,14,0,0" FontSize="18" FontWeight="SemiBold" Text="{Binding SelectedPointName}" TextWrapping="Wrap" />
                            <TextBlock Margin="0,6,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedPointDeviceCode}" />

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="92" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="状态" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedPointStatusText}" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource FieldLabelStyle}" Text="目录" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedPointDirectoryPath}" TextWrapping="Wrap" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource FieldLabelStyle}" Text="来源" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedCoordinateSourceText}" />

                                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource FieldLabelStyle}" Text="坐标" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedCoordinateText}" />

                                <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource FieldLabelStyle}" Text="更新时间" />
                                <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedCoordinateUpdatedText}" />
                            </Grid>

                            <TextBlock Margin="0,18,0,6" Style="{StaticResource FieldLabelStyle}" Text="备注" />
                            <TextBlock Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedCoordinateRemarkText}" TextWrapping="Wrap" />

                            <Border Margin="0,18,0,0"
                                    Padding="14"
                                    Background="{DynamicResource MetricTileBackgroundBrush}"
                                    BorderBrush="{Binding SelectedClosureStatusAccentResourceKey, Converter={StaticResource ResourceLookupConverter}}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource InnerCardCornerRadius}">
                                <StackPanel>
                                    <DockPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="闭环摘要" />
                                        <Border DockPanel.Dock="Right"
                                                Style="{StaticResource StatusBadgeBorderStyle}"
                                                BorderBrush="{Binding SelectedClosureStatusAccentResourceKey, Converter={StaticResource ResourceLookupConverter}}">
                                            <TextBlock Text="{Binding SelectedClosureStatusText}" />
                                        </Border>
                                    </DockPanel>

                                    <Grid Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="92" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="复核结论" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedClosureReviewConclusionText}" />

                                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource FieldLabelStyle}" Text="最近复检" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedClosureLatestRecheckText}" TextWrapping="Wrap" />

                                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource FieldLabelStyle}" Text="待办标记" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedClosurePendingFlagsText}" TextWrapping="Wrap" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelCardStyle}">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="基础巡检" />
                                <Border DockPanel.Dock="Right"
                                        Style="{StaticResource MiniBadgeStyle}"
                                        Background="{DynamicResource FilterBadgeBackgroundBrush}">
                                    <TextBlock Text="{Binding SelectedInspectionResult.PlaybackHealthGrade, TargetNullValue=待检}" />
                                </Border>
                            </DockPanel>

                            <TextBlock Margin="0,12,0,0"
                                       Style="{StaticResource SectionHintStyle}"
                                       Text="{Binding InspectionStatusText}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="{DynamicResource ToneDangerBrush}"
                                       Text="{Binding InspectionAlertText}"
                                       TextWrapping="Wrap" />

                            <WrapPanel Margin="0,16,0,0">
                                <Button Style="{StaticResource ActionButtonStyle}"
                                        Command="{Binding ExecuteInspectionCommand}"
                                        IsEnabled="{Binding CanInspectSelectedPoint}"
                                        Content="{Binding InspectButtonText}" />
                                <Button Style="{StaticResource ActionButtonStyle}"
                                        IsEnabled="False"
                                        Content="批量巡检（预留）" />
                            </WrapPanel>

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="92" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="最近巡检" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedInspectionResult.InspectionTimeText, TargetNullValue=待检}" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource FieldLabelStyle}" Text="播放等级" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedInspectionResult.PlaybackHealthSummary, TargetNullValue=待检}" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource FieldLabelStyle}" Text="最优协议" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedInspectionResult.PreferredProtocolText, TargetNullValue=--}" />

                                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource FieldLabelStyle}" Text="备用协议" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedInspectionResult.FallbackProtocolText, TargetNullValue=--}" />

                                <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource FieldLabelStyle}" Text="有效期" />
                                <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedInspectionResult.ExpireTimeText, TargetNullValue=--}" />

                                <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource FieldLabelStyle}" Text="视频编码" />
                                <TextBlock Grid.Row="5" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedInspectionResult.VideoEncText, TargetNullValue=--}" />

                                <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,10,0,0" Style="{StaticResource FieldLabelStyle}" Text="最近失败" />
                                <TextBlock Grid.Row="6" Grid.Column="1" Margin="0,10,0,0" Style="{StaticResource FieldValueStyle}" Text="{Binding SelectedInspectionResult.FailureReasonText, TargetNullValue=无}" TextWrapping="Wrap" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <sharedPages:DeviceMediaReviewPanelView DataContext="{Binding MediaReview}" />

                    <Border Style="{StaticResource PanelCardStyle}">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="人工坐标治理" />
                                <Border DockPanel.Dock="Right" Style="{StaticResource MiniBadgeStyle}" Background="{DynamicResource FilterBadgeBackgroundBrush}">
                                    <TextBlock Text="GCJ-02" />
                                </Border>
                            </DockPanel>

                            <TextBlock Margin="0,14,0,0" Style="{StaticResource SectionHintStyle}" Text="{Binding EditorStatusText}" TextWrapping="Wrap" />
                            <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource ToneDangerBrush}" Text="{Binding EditorErrorText}" TextWrapping="Wrap" />

                            <TextBlock Margin="0,18,0,6" Style="{StaticResource FieldLabelStyle}" Text="经度" />
                            <TextBox Text="{Binding EditorLongitude, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,14,0,6" Style="{StaticResource FieldLabelStyle}" Text="纬度" />
                            <TextBox Text="{Binding EditorLatitude, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,14,0,6" Style="{StaticResource FieldLabelStyle}" Text="备注" />
                            <TextBox Height="80"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"
                                     Text="{Binding EditorRemark, UpdateSourceTrigger=PropertyChanged}" />

                            <WrapPanel Margin="0,18,0,0">
                                <Button Style="{StaticResource ActionButtonStyle}"
                                        Command="{Binding TogglePickModeCommand}"
                                        IsEnabled="{Binding HasSelectedPoint}"
                                        Content="地图取点" />
                                <Button Style="{StaticResource ActionButtonStyle}"
                                        Command="{Binding SaveManualCoordinateCommand}"
                                        IsEnabled="{Binding HasSelectedPoint}"
                                        Content="保存人工坐标" />
                                <Button Style="{StaticResource ActionButtonStyle}"
                                        Command="{Binding ClearManualCoordinateCommand}"
                                        IsEnabled="{Binding HasSelectedPoint}"
                                        Content="清除人工坐标" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelCardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="待补录坐标" />
                            <TextBlock Margin="0,10,0,0" Style="{StaticResource SectionHintStyle}" Text="不落地图，但继续纳入当前方案统计和联动列表。" TextWrapping="Wrap" />
                            <TextBlock Margin="0,8,0,12" Style="{StaticResource SectionHintStyle}" Text="{Binding MissingCoordinateItems.Count, StringFormat='当前 {0} 个点位待补录'}" />

                            <ItemsControl ItemsSource="{Binding MissingCoordinateItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Margin="0,0,0,10"
                                                Command="{Binding DataContext.SelectMissingCoordinateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource SelectionButtonStyle}">
                                                    <Setter Property="Margin" Value="0,0,0,10" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Tag" Value="Selected" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="Wrap" />
                                                <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource SecondaryTextBrush}" Text="{Binding Subtitle}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
